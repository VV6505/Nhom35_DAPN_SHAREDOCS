@{
    Layout = null;
}
<!doctype html>
<html lang="vi">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>UTE-DN DocShare | Quản trị viên</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;1,14..32,400&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0a0d14;
      --surface: #111520;
      --surface2: #181d2c;
      --border: rgba(255,255,255,.07);
      --border-focus: rgba(255,179,0,.5);
      --accent: #FFB300;
      --accent-dim: rgba(255,179,0,.12);
      --red: #ef4444;
      --white: #ffffff;
      --muted: rgba(255,255,255,.4);
      --text: rgba(255,255,255,.88);
      --radius: 13px;
      --transition: .22s cubic-bezier(.4,0,.2,1);
    }

    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      font-feature-settings: 'cv02','cv03','cv04','cv11';
      -webkit-font-smoothing: antialiased;
      background: var(--bg);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px 16px;
      position: relative;
      overflow: hidden;
    }

    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
    }

    .blob { position: fixed; border-radius: 50%; pointer-events: none; filter: blur(80px); opacity: .35; }
    .blob-1 { width: 500px; height: 500px; background: rgba(255,179,0,.15); top: -150px; right: -100px; animation: drift 12s ease-in-out infinite alternate; }
    .blob-2 { width: 350px; height: 350px; background: rgba(99,102,241,.12); bottom: -100px; left: -50px; animation: drift 9s 2s ease-in-out infinite alternate-reverse; }

    @@keyframes drift {
      from { transform: translate(0,0); }
      to   { transform: translate(30px, 20px); }
    }

    /* ── CARD ─────────────────────────────────── */
    .card {
      position: relative; z-index: 1;
      width: min(440px, 100%);
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 22px;
      padding: 44px 40px;
      box-shadow: 0 32px 80px rgba(0,0,0,.6);
      animation: fadeIn .55s cubic-bezier(.4,0,.2,1) both;
    }

    @@keyframes fadeIn {
      from { opacity: 0; transform: translateY(24px) scale(.98); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* ── TOP BADGE ────────────────────────────── */
    .badge {
      display: inline-flex; align-items: center; gap: 7px;
      background: var(--accent-dim);
      border: 1px solid rgba(255,179,0,.2);
      border-radius: 999px;
      padding: 5px 12px;
      margin-bottom: 28px;
      animation: fadeIn .5s .1s both;
    }
    .badge-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 6px var(--accent);
      animation: pulse 1.8s ease infinite;
    }
    @@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
    .badge-text { font-size: 11px; font-weight: 500; letter-spacing: 1.5px; text-transform: uppercase; color: var(--accent); }

    /* ── BRAND ────────────────────────────────── */
    .brand { display: flex; align-items: center; gap: 12px; margin-bottom: 28px; animation: fadeIn .5s .15s both; }
    .brand-mark {
      width: 52px; height: 52px; border-radius: 13px;
      background: rgba(255,255,255,.06);
      border: 1px solid rgba(255,255,255,.1);
      display: grid; place-items: center; overflow: hidden;
    }
    .brand-mark img { width: 42px; height: 42px; object-fit: contain; }
    .brand-name { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; font-weight: 700; color: var(--white); font-size: 14px; letter-spacing: -.2px; }
    .brand-sub { font-size: 11px; color: var(--muted); margin-top: 2px; letter-spacing: .3px; font-family: 'Inter', monospace; }

    /* ── HEADLINE ─────────────────────────────── */
    .headline { animation: fadeIn .5s .2s both; }
    .headline h1 {
      font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
      font-size: 26px; font-weight: 800;
      color: var(--white); letter-spacing: -.5px; line-height: 1.15;
    }
    .headline p { color: var(--muted); font-size: 14px; margin-top: 8px; line-height: 1.65; font-weight: 400; }

    .sep { height: 1px; background: var(--border); margin: 28px 0; animation: fadeIn .5s .25s both; }

    /* ── FORM ─────────────────────────────────── */
    .form { animation: fadeIn .5s .3s both; }

    .field { display: flex; flex-direction: column; gap: 8px; }
    .field + .field { margin-top: 16px; }

    .field-label {
      font-size: 11.5px; font-weight: 600; letter-spacing: .5px; text-transform: uppercase;
      color: var(--muted);
      display: flex; align-items: center; gap: 6px;
    }
    .field-label svg { opacity: .5; }

    .input-wrap { position: relative; }

    .input {
      width: 100%; padding: 13px 14px 13px 44px;
      background: var(--surface2);
      border: 1.5px solid var(--border);
      border-radius: var(--radius);
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 14px; font-weight: 400; color: var(--white);
      outline: none;
      transition: var(--transition);
    }
    .input::placeholder { color: rgba(255,255,255,.2); font-family: 'Inter', system-ui, sans-serif; }
    .input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-dim); }
    .input.err { border-color: var(--red); box-shadow: 0 0 0 3px rgba(239,68,68,.1); }

    .input-icon {
      position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
      color: var(--muted); pointer-events: none; width: 16px; height: 16px;
    }

    .eye-btn {
      position: absolute; right: 14px; top: 50%; transform: translateY(-50%);
      background: none; border: none; cursor: pointer; color: var(--muted);
      padding: 0; display: grid; place-items: center; transition: var(--transition);
    }
    .eye-btn:hover { color: var(--white); }

    .field-err {
      font-size: 12px; color: var(--red);
      display: none; align-items: center; gap: 5px;
    }
    .field-err.show { display: flex; }

    .row { display: flex; align-items: center; margin-top: 20px; }
    .remember { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--muted); cursor: pointer; }
    .remember input[type="checkbox"] { width: 15px; height: 15px; accent-color: var(--accent); }

    .general-err {
      margin-top: 14px; padding: 11px 14px;
      border-radius: 10px;
      background: rgba(239,68,68,.08); border: 1px solid rgba(239,68,68,.2);
      font-size: 13px; color: var(--red);
      display: none; align-items: center; gap: 8px;
    }
    .general-err.show { display: flex; }

    .btn-login {
      width: 100%; margin-top: 24px; padding: 14px;
      border: none; border-radius: var(--radius);
      background: var(--accent);
      color: #000;
      font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
      font-size: 15px; font-weight: 700;
      letter-spacing: .1px;
      cursor: pointer;
      position: relative; overflow: hidden;
      transition: var(--transition);
    }
    .btn-login::after {
      content: '';
      position: absolute; inset: 0;
      background: rgba(0,0,0,.12); opacity: 0;
      transition: var(--transition);
    }
    .btn-login:hover { box-shadow: 0 8px 28px rgba(255,179,0,.35); transform: translateY(-1px); }
    .btn-login:hover::after { opacity: 1; }
    .btn-login:active { transform: translateY(0); }
    .btn-login span { position: relative; z-index: 1; }
    .btn-login:disabled { opacity: .6; cursor: not-allowed; transform: none; }

    /* ── FOOTER ───────────────────────────────── */
    .card-footer {
      margin-top: 28px; padding-top: 20px;
      border-top: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
      animation: fadeIn .5s .4s both;
    }
    .user-link { font-size: 13px; color: var(--muted); }
    .user-link a { color: var(--accent); font-weight: 500; text-decoration: none; }
    .user-link a:hover { text-decoration: underline; }
    .version { font-family: 'Inter', monospace; font-size: 10px; color: rgba(255,255,255,.18); letter-spacing: .5px; }
  </style>
</head>
<body>

  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>

  <div class="card">

    <div class="badge">
      <div class="badge-dot"></div>
      <span class="badge-text">Quản trị viên</span>
    </div>

    <div class="brand">
      <div class="brand-mark">
           <img src="~/images/logo.webp" alt="UTE Logo" />
      </div>
      <div>
        <div class="brand-name">UTE-DN DocShare</div>
        <div class="brand-sub">ADMIN PORTAL</div>
      </div>
    </div>

    <div class="headline">
      <h1>Truy cập hệ thống</h1>
      <p>Chỉ dành cho quản trị viên được ủy quyền</p>
    </div>

    <div class="sep"></div>

    <form asp-controller="Auth" asp-action="Login" method="post" id="frmAdmin" class="form" novalidate>
      <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

      <div class="field">
        <label class="field-label" for="username">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
          </svg>
          Định danh tài khoản
        </label>
        <div class="input-wrap">
          <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
          <input id="username" name="username"
                 class="input @(ViewBag.Error != null ? "err" : "")"
                 type="text" placeholder="ADMIN" autocomplete="username" required />
        </div>
        <div id="errTenTK" class="field-err">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          <span id="errTenTKMsg"></span>
        </div>
      </div>

      <div class="field">
        <label class="field-label" for="password">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          Mật khẩu bảo mật
        </label>
        <div class="input-wrap">
          <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          <input id="password" name="password"
                 class="input @(ViewBag.Error != null ? "err" : "")"
                 type="password" placeholder="••••••••••"
                 autocomplete="current-password" required />
          <button type="button" class="eye-btn" id="eyeBtn" aria-label="Hiện/ẩn">
            <svg id="eyeIcon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </button>
        </div>
        <div id="errMatKhau" class="field-err">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          <span id="errMatKhauMsg"></span>
        </div>
      </div>

      <div class="row">
        <label class="remember">
          <input type="checkbox" name="remember" id="remember" /> Giữ đăng nhập
        </label>
      </div>

      @if (ViewBag.Error != null)
      {
          <div class="general-err show">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <line x1="12" y1="8" x2="12" y2="12"/>
                  <line x1="12" y1="16" x2="12.01" y2="16"/>
              </svg>
              <span>@ViewBag.Error</span>
          </div>
      }
      else
      {
          <div class="general-err" id="errGeneral">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <line x1="12" y1="8" x2="12" y2="12"/>
                  <line x1="12" y1="16" x2="12.01" y2="16"/>
              </svg>
              <span id="errGeneralMsg"></span>
          </div>
      }

      <button class="btn-login" type="submit" id="btnSubmit">
        <span>Xác thực &amp; Đăng nhập</span>
      </button>
    </form>

    <div class="card-footer">
      <div class="user-link">
        Không phải admin? <a href="https://localhost:7287/Auth/Login">← Đăng nhập thường</a>
      </div>
      <div class="version">v2.4.1</div>
    </div>

  </div>

  <script>
    (function () {
      const pwInput = document.getElementById('password');
      document.getElementById('eyeBtn').addEventListener('click', () => {
        const show = pwInput.type === 'password';
        pwInput.type = show ? 'text' : 'password';
        document.getElementById('eyeIcon').innerHTML = show
          ? '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>'
          : '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
      });

      document.getElementById('frmAdmin').addEventListener('submit', function (e) {
        const u = (document.getElementById('username').value || '').trim();
        const p = (document.getElementById('password').value || '').trim();

        document.getElementById('errTenTK').classList.remove('show');
        document.getElementById('errMatKhau').classList.remove('show');
        const genErr = document.getElementById('errGeneral');
        if (genErr) genErr.classList.remove('show');

        let ok = true;
        if (!u) {
          document.getElementById('errTenTKMsg').textContent = 'Vui lòng nhập định danh tài khoản.';
          document.getElementById('errTenTK').classList.add('show');
          document.getElementById('username').classList.add('err');
          ok = false;
        }
        if (!p) {
          document.getElementById('errMatKhauMsg').textContent = 'Vui lòng nhập mật khẩu.';
          document.getElementById('errMatKhau').classList.add('show');
          document.getElementById('password').classList.add('err');
          ok = false;
        }
        if (!ok) { e.preventDefault(); return; }

        const btn = document.getElementById('btnSubmit');
        btn.disabled = true;
        btn.querySelector('span').textContent = 'Đang xác thực...';
      });
    })();
  </script>
</body>
</html>

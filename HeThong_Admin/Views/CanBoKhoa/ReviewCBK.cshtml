@model List<HeThong_Admin.Controllers.WorkflowDocDto>
@{
    ViewData["Title"] = "Duyệt tài liệu khoa";
}

<div class="content-wrapper p-4">
    <!-- Header Section -->
    <div class="card border-0 shadow-sm rounded-4 mb-4 bg-gradient-header">
        <div class="card-body p-4">
            <h1 class="page-title mb-1">⚖️ Duyệt tài liệu khoa</h1>
            <p class="page-subtitle mb-0 opacity-75">Phê duyệt tài liệu thuộc khoa quản lý trước khi gửi lên hệ thống</p>
        </div>
    </div>

    <div id="wrap">
        @if (!Model.Any())
        {
            <div class="card border-0 shadow-sm rounded-4 p-5 text-center">
                <div class="mb-3 fs-1">✅</div>
                <h3 class="fw-bold">Không có tài liệu nào chờ duyệt</h3>
                <p class="text-muted">Hiện không có tài liệu nào cần bạn phê duyệt tại khoa này.</p>
            </div>
        }
        else
        {
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover leaderboard-table mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4">ID</th>
                                <th>Thông tin tài liệu</th>
                                <th class="text-center">Trạng thái</th>
                                <th class="text-end pe-4">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in Model)
                            {
                                <tr class="rank-row" data-id="@t.maTaiLieu">
                                    <td class="ps-4 align-middle">
                                        <span class="text-muted font-monospace">#@t.maTaiLieu</span>
                                    </td>
                                    <td class="align-middle">
                                        <div class="fw-bold fs-16 text-dark">@t.tieuDe</div>
                                        <div class="text-muted small">@t.loaiFile • Đăng lúc: @(t.ngayDang?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div>
                                    </td>
                                    <td class="text-center align-middle">
                                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-3 py-2 rounded-pill">
                                            ⏳ @t.trangThaiDuyet
                                        </span>
                                    </td>
                                    <td class="text-end pe-4 align-middle">
                                        <div class="d-flex gap-2 justify-content-end">
                                            <button class="btn btn-success btn-sm px-3 fw-bold" onclick="handleAction('@t.maTaiLieu', 'approve')">Duyệt</button>
                                            <button class="btn btn-outline-danger btn-sm px-3 fw-bold" onclick="handleAction('@t.maTaiLieu', 'reject')">Từ chối</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .bg-gradient-header {
        background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
        color: white;
    }
    .bg-gradient-header .page-title { color: white; font-size: 32px; font-weight: 800; }
    .bg-gradient-header .page-subtitle { color: #cbd5e1; font-size: 15px; }

    .leaderboard-table thead th {
        background: #f8fafc;
        padding: 18px 12px;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #64748b;
    }
    .rank-row td { padding: 20px 12px; }
    .fs-16 { font-size: 16px; }
</style>

@section Scripts {
    <script>
        async function handleAction(id, action) {
            try {
                if (action === 'approve') {
                    if (!confirm('Bạn xác nhận duyệt tài liệu này và gửi lên Admin?')) return;
                    
                    const res = await fetch('@Url.Action("CBKApprove", "CanBoKhoa")', {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ maTaiLieu: id })
                    });

                    if (res.ok) {
                        document.querySelector(`tr[data-id="${id}"]`).remove();
                        if (document.querySelectorAll('tbody tr').length === 0) location.reload();
                    } else {
                        alert('Có lỗi xảy ra khi phê duyệt.');
                    }
                } else {
                    const reason = prompt("Nhập lý do từ chối:");
                    if (reason === null) return;
                    if (!reason.trim()) {
                        alert('Vui lòng nhập lý do từ chối.');
                        return;
                    }

                    const res = await fetch('@Url.Action("Reject", "CanBoKhoa")', {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ maTaiLieu: id, lyDoTuChoi: reason })
                    });

                    if (res.ok) {
                        document.querySelector(`tr[data-id="${id}"]`).remove();
                        if (document.querySelectorAll('tbody tr').length === 0) location.reload();
                    } else {
                        alert('Có lỗi xảy ra khi từ chối.');
                    }
                }
            } catch (e) {
                console.error(e);
                alert('Lỗi kết nối hệ thống.');
            }
        }
    </script>
}

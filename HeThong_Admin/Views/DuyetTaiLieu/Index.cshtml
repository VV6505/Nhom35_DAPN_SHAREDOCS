@model List<HeThong_User.Models.TaiLieu>
@{
    ViewData["Title"] = "Duyệt tài liệu";
    var trangthai = ViewBag.TrangThai as string ?? "all";
    var khoaFilter = ViewBag.Khoa as string ?? "all";
    var search = ViewBag.Search as string ?? "";
    var khoas = ViewBag.Khoas as List<HeThong_User.Models.Khoa>;
    var nguoiDangMap = ViewBag.NguoiDangMap as Dictionary<string, string> ?? new Dictionary<string, string>();
}

<div class="content">
    <h1 class="page-title">Duyệt tài liệu</h1>
    <p class="page-subtitle">Kiểm duyệt nội dung tài liệu trước khi hiển thị công khai</p>

    <div class="card">
        <!-- Bộ lọc -->
        <div class="action-bar">
            <form method="get" asp-action="Index" style="display:flex; gap:10px; align-items:center; width:100%;">
                <select name="trangthai">
                    <option value="all" selected="@(trangthai == "all")">Tất cả trạng thái</option>
                    <option value="Chờ duyệt" selected="@(trangthai == "Chờ duyệt")">Chờ khoa duyệt</option>
                    <option value="Chờ Admin duyệt" selected="@(trangthai == "Chờ Admin duyệt")">Chờ Admin duyệt</option>
                    <option value="Đã duyệt" selected="@(trangthai == "Đã duyệt")">Đã duyệt</option>
                    <option value="Từ chối" selected="@(trangthai == "Từ chối")">Từ chối</option>
                </select>
                <select name="khoa">
                    <option value="all" selected="@(khoaFilter == "all")">Tất cả khoa</option>
                    @if (khoas != null)
                    {
                        foreach (var k in khoas)
                        {
                            <option value="@k.MaKhoa" selected="@(khoaFilter == k.MaKhoa)">@k.TenKhoa</option>
                        }
                    }
                </select>
                <input type="text" name="search" value="@search" placeholder="🔍 Tìm tài liệu..." />
                <button type="submit" class="btn btn-primary btn-action">🔍 Tìm kiếm</button>
                <a href="@Url.Action("Index")" class="btn btn-outline btn-action">↺ Đặt lại</a>
            </form>
        </div>

        <!-- Bảng tài liệu -->
        <table>
            <thead>
                <tr>
                    <th>Tên tài liệu</th>
                    <th>Người đăng</th>
                    <th>Môn học</th>
                    <th>Ngày đăng</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    foreach (var tl in Model)
                    {
                        var tenNguoiDang = "—";
                        if (!string.IsNullOrEmpty(tl.MaNguoiDang) && nguoiDangMap.ContainsKey(tl.MaNguoiDang))
                        {
                            tenNguoiDang = nguoiDangMap[tl.MaNguoiDang];
                        }
                        var monHoc = tl.MaMonHocNavigation?.TenMonHoc ?? "—";
                        var badgeClass = tl.TrangThaiDuyet switch
                        {
                            "Đã duyệt" => "approved",
                            "Chờ duyệt" => "pending",
                            "Chờ Admin duyệt" => "pending-admin",
                            "Từ chối" => "rejected",
                            _ => ""
                        };
                        var badgeText = tl.TrangThaiDuyet switch
                        {
                            "Đã duyệt" => "Đã duyệt",
                            "Chờ duyệt" => "Chờ khoa duyệt",
                            "Chờ Admin duyệt" => "Chờ Admin duyệt",
                            "Từ chối" => "Từ chối",
                            _ => tl.TrangThaiDuyet ?? "—"
                        };
                        <tr>
                            <td><strong>@tl.TieuDe</strong></td>
                            <td>@tenNguoiDang</td>
                            <td>@monHoc</td>
                            <td>@(tl.NgayDang?.ToString("dd/MM/yyyy") ?? "—")</td>
                            <td><span class="badge @badgeClass">@badgeText</span></td>
                            <td>
                                <div class="btn-group">
                                    @if (tl.TrangThaiDuyet == "Chờ duyệt" || tl.TrangThaiDuyet == "Chờ Admin duyệt")
                                    {
                                        <form method="post" asp-action="Duyet" asp-route-id="@tl.MaTaiLieu" style="display:inline;">
                                            <button type="submit" class="btn btn-success">Duyệt</button>
                                        </form>
                                        <form method="post" asp-action="TuChoi" asp-route-id="@tl.MaTaiLieu" style="display:inline;">
                                            <button type="submit" class="btn btn-danger">Từ chối</button>
                                        </form>
                                    }
                                    else if (tl.TrangThaiDuyet == "Đã duyệt")
                                    {
                                        <form method="post" asp-action="Xoa" asp-route-id="@tl.MaTaiLieu" style="display:inline;"
                                              onsubmit="return confirm('Xóa tài liệu này?');">
                                            <button type="submit" class="btn btn-danger">Xóa</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="6" class="empty">Không có tài liệu nào</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@model List<HeThong_User.Models.TaiKhoan>
@{
    ViewData["Title"] = "Quản lý người dùng";
    var search = ViewBag.Search as string ?? "";
    var vaitro = ViewBag.VaiTro as string ?? "all";
    var trangthai = ViewBag.TrangThai as string ?? "all";
    var vaiTros = ViewBag.VaiTros as List<HeThong_User.Models.VaiTro>;
}

<div class="content">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="page-title mb-1">Quản lý người dùng</h1>
            <p class="page-subtitle">Xem, phân quyền và quản lý tài khoản trong hệ thống</p>
        </div>
        <div class="dropdown-custom">
            <button class="btn btn-success" type="button" onclick="toggleAddMenu(event)">
                + Thêm mới <span style="font-size: 10px; margin-left: 5px;">▼</span>
            </button>
            <ul class="dropdown-menu-custom shadow" id="addMenu">
                <li><a class="dropdown-item-custom" href="javascript:void(0)" onclick="openAddModal('SV')">🎓 Thêm Sinh viên</a></li>
                <li><a class="dropdown-item-custom" href="javascript:void(0)" onclick="openAddModal('GV')">👨‍🏫 Thêm Giảng viên</a></li>
            </ul>
        </div>
    </div>

    <div class="card">
        <!-- Bộ lọc -->
        <div class="action-bar">
            <form method="get" asp-action="Index" style="display:flex; gap:10px; align-items:center; flex-wrap:wrap; width:100%;">
                <input type="text" name="search" value="@search" placeholder="🔍 Tìm theo tên, email..." style="flex:1; min-width:200px; max-width:280px;" />
                <select name="vaitro">
                    <option value="all" selected="@(vaitro == "all")">Tất cả vai trò</option>
                    @if (vaiTros != null)
                    {
                        foreach (var vt in vaiTros)
                        {
                                    <option value="@vt.MaVaiTro" selected="@(vaitro == vt.MaVaiTro)">@vt.TenVaiTro</option>
                        }
                    }
                </select>
                <select name="trangthai">
                    <option value="all" selected="@(trangthai == "all")">Tất cả trạng thái</option>
                    <option value="1" selected="@(trangthai == "1")">Đang hoạt động</option>
                    <option value="0" selected="@(trangthai == "0")">Tạm khóa</option>
                </select>
                <button type="submit" class="btn btn-primary btn-action">🔍 Tìm kiếm</button>
                <a href="@Url.Action("Index")" class="btn btn-outline btn-action">↺ Đặt lại</a>
            </form>
        </div>

        <!-- Bảng danh sách -->
        <table>
            <thead>
                <tr>
                    <th>Mã tài khoản</th>
                    <th>Họ tên</th>
                    <th>Vai trò</th>
                    <th>Điểm</th>
                    <th>Trạng thái</th>
                    <th style="width: 1%; white-space: nowrap; text-align: center;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    foreach (var tk in Model)
                    {
                        var maSo = tk.MaTk;
                        var tenHienThi = "";
                        var diem = "—";
                        var vaiTroText = tk.MaVaiTroNavigation?.TenVaiTro ?? "—";

                        var sv = tk.MaSvNavigation;
                        var gv = tk.MaGvNavigation;

                        if (sv != null)
                        {
                            maSo = sv.MaSv;
                            tenHienThi = sv.TenSv;
                            diem = (sv.DiemTichLuy ?? 0).ToString();
                        }
                        else if (gv != null)
                        {
                            maSo = gv.MaGv;
                            tenHienThi = gv.TenGv;
                        }
                        else
                        {
                            tenHienThi = tk.TenTk;
                        }

                        var isActive = tk.TrangThai == 1;
                        var isAdminAccount = tk.MaTk.Trim() == "ADMIN" || tk.MaVaiTro?.Trim() == "VT001";
                                <tr>
                                    <td>@maSo</td>  
                                    <td><strong>@tenHienThi</strong></td>
                                    <td>@vaiTroText</td>
                                    <td>@diem</td>
                                    <td>
                                        <span class="status-dot @(isActive ? "active" : "locked")"></span>
                                        @(isActive ? "Hoạt động" : "Tạm khóa")
                                    </td>
                                    <td style="text-align: center; white-space: nowrap;">
                                        <div class="btn-group" style="justify-content: center; flex-wrap: nowrap;">
                                            <button class="btn btn-outline btn-sm" style="white-space: nowrap; padding: 6px 12px;" onclick="viewDetails('@tk.MaTk')">Chi tiết</button>
                                            
                                            @if (!isAdminAccount)
                                            {
                                                @if (isActive)
                                                {
                                                    <form method="post" asp-action="KhoaTaiKhoan" asp-route-id="@tk.MaTk" style="display:inline;">
                                                        <button type="submit" class="btn btn-danger btn-sm" style="white-space: nowrap; padding: 6px 12px;">Khóa</button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <form method="post" asp-action="MoKhoaTaiKhoan" asp-route-id="@tk.MaTk" style="display:inline;">
                                                        <button type="submit" class="btn btn-success btn-sm" style="white-space: nowrap; padding: 6px 12px;">Mở khóa</button>
                                                    </form>
                                                }
                                                <form method="post" asp-action="XoaTaiKhoan" asp-route-id="@tk.MaTk" style="display:inline;"
                                                      onsubmit="return confirm('Bạn có chắc muốn xóa tài khoản này?');">
                                                    <button type="submit" class="btn btn-outline btn-sm text-danger" style="white-space: nowrap; padding: 6px 12px;">Xóa</button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                    }
                }
                else
                {
                        <tr><td colspan="6" class="empty">Không tìm thấy người dùng nào</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Chi Tiết -->
<div id="userModal" class="modal-overlay" style="display:none;">
    <div class="modal-card">
        <div class="modal-header">
            <h3 id="modalTitle">Thông tin chi tiết</h3>
            <button class="close-btn" onclick="closeModal()">&times;</button>
        </div>
        <div class="modal-body" id="modalContent">
            <!-- Nội dung chi tiết sẽ đổ vào đây -->
        </div>
    </div>
</div>

<!-- Modal Thêm Sinh Viên -->
<div id="addSvModal" class="modal-overlay" style="display:none;">
    <div class="modal-card">
        <div class="modal-header">
            <h3>Thêm Sinh viên mới</h3>
            <button class="close-btn" onclick="closeAddModal('SV')">&times;</button>
        </div>
        <form id="formAddSv" onsubmit="submitAdd(event, 'SV')">
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold small text-muted">MÃ SINH VIÊN</label>
                        <input type="text" name="MaSv" class="form-control" required placeholder="VD: SV001" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold small text-muted">HỌ VÀ TÊN</label>
                        <input type="text" name="TenSv" class="form-control" required placeholder="Nhập họ tên" />
                    </div>
                    <div class="col-md-12 mb-3">
                        <label class="form-label fw-bold small text-muted">EMAIL</label>
                        <input type="email" name="Email" class="form-control" required placeholder="example@gmail.com" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold small text-muted">LỚP HỌC</label>
                        <select name="MaLop" class="form-control" required>
                            <option value="">-- Chọn lớp --</option>
                            @foreach (var lop in ViewBag.Lops as List<HeThong_User.Models.Lop> ?? new())
                            {
                                <option value="@lop.MaLop">@lop.TenLop (@lop.MaLop)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold small text-muted">GIỚI TÍNH</label>
                        <select name="GioiTinh" class="form-control">
                            <option value="Nam">Nam</option>
                            <option value="Nữ">Nữ</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer p-3 bg-light border-top text-end">
                <button type="button" class="btn btn-outline" onclick="closeAddModal('SV')">Hủy</button>
                <button type="submit" class="btn btn-success px-4">Lưu thông tin</button>
            </div>
        </form>
    </div>
</div>

<!-- Modal Thêm Giảng Viên -->
<div id="addGvModal" class="modal-overlay" style="display:none;">
    <div class="modal-card">
        <div class="modal-header">
            <h3>Thêm Giảng viên mới</h3>
            <button class="close-btn" onclick="closeAddModal('GV')">&times;</button>
        </div>
        <form id="formAddGv" onsubmit="submitAdd(event, 'GV')">
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold small text-muted">MÃ GIẢNG VIÊN</label>
                        <input type="text" name="MaGv" class="form-control" required placeholder="VD: GV001" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold small text-muted">HỌ VÀ TÊN</label>
                        <input type="text" name="TenGv" class="form-control" required placeholder="Nhập họ tên" />
                    </div>
                    <div class="col-md-12 mb-3">
                        <label class="form-label fw-bold small text-muted">EMAIL</label>
                        <input type="email" name="Email" class="form-control" required placeholder="example@ute.udn.vn" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold small text-muted">KHOA</label>
                        <select name="MaKhoa" class="form-control" required>
                            <option value="">-- Chọn khoa --</option>
                            @foreach (var khoa in ViewBag.Khoas as List<HeThong_User.Models.Khoa> ?? new())
                            {
                                <option value="@khoa.MaKhoa">@khoa.TenKhoa</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold small text-muted">LOẠI CÁN BỘ</label>
                        <select name="LoaiGv" class="form-control">
                            <option value="GV">Giảng viên</option>
                            <option value="CBK">Cán bộ khoa</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer p-3 bg-light border-top text-end">
                <button type="button" class="btn btn-outline" onclick="closeAddModal('GV')">Hủy</button>
                <button type="submit" class="btn btn-primary px-4">Lưu thông tin</button>
            </div>
        </form>
    </div>
</div>

<style>
    .modal-overlay {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(15, 23, 42, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        backdrop-filter: blur(4px);
    }
    .modal-card {
        background: white;
        width: 100%;
        max-width: 500px;
        border-radius: 16px;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        overflow: hidden;
    }
    .modal-header {
        padding: 20px;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #f8fafc;
    }
    .modal-header h3 { margin: 0; font-size: 18px; font-weight: 800; color: #1e293b; }
    .close-btn { background: none; border: none; font-size: 24px; cursor: pointer; color: #64748b; }
    .modal-body { padding: 24px; }
    .detail-item { margin-bottom: 16px; display: flex; border-bottom: 1px dashed #f1f5f9; padding-bottom: 8px; }
    .detail-label { width: 140px; font-weight: 600; color: #64748b; font-size: 14px; }
    .detail-value { flex: 1; color: #1e293b; font-weight: 700; font-size: 14px; }
    .text-danger { color: #ef4444 !important; }

    /* Custom Dropdown Styles */
    .dropdown-custom { position: relative; }
    .dropdown-menu-custom {
        display: none;
        position: absolute;
        top: 100%;
        right: 0;
        min-width: 200px;
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        z-index: 1000;
        margin-top: 8px;
        padding: 8px 0;
    }
    .dropdown-menu-custom.show { display: block; }
    .dropdown-item-custom {
        display: block;
        padding: 10px 20px;
        color: #475569;
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        transition: background 0.2s;
    }
    .dropdown-item-custom:hover { background: #f1f5f9; color: #2563eb; }
</style>

@section Scripts {
    <script>
        async function viewDetails(id) {
            const modal = document.getElementById('userModal');
            const content = document.getElementById('modalContent');
            
            content.innerHTML = '<div class="text-center p-4">Đang tải...</div>';
            modal.style.display = 'flex';

            try {
                const res = await fetch(`@Url.Action("GetDetails", "NguoiDung")/${id}`);
                const data = await res.json();
                
                let html = `
                    <div class="text-center mb-4">
                        <div class="badge approved px-3 py-2 rounded-pill mb-2">${data.type}</div>
                        <h4 class="fw-bold mb-0">${data.name}</h4>
                    </div>
                `;

                const fields = [];
                if(data.type === "Sinh viên") {
                    fields.push({ label: "Mã sinh viên", value: data.code });
                    fields.push({ label: "Email", value: data.email });
                    fields.push({ label: "Lớp", value: data.className });
                    fields.push({ label: "Khoa", value: data.facultyName });
                    fields.push({ label: "Ngày sinh", value: data.dob });
                    fields.push({ label: "Giới tính", value: data.gender });
                    fields.push({ label: "Điểm tích lũy", value: data.points });
                    fields.push({ label: "Trạng thái", value: data.status });
                } else if(data.type === "Giảng viên") {
                    fields.push({ label: "Mã giảng viên", value: data.code });
                    fields.push({ label: "Email", value: data.email });
                    fields.push({ label: "Số điện thoại", value: data.phone });
                    fields.push({ label: "Học vị", value: data.degree });
                    fields.push({ label: "Khoa", value: data.facultyName });
                    fields.push({ label: "Loại cán bộ", value: data.roleInFaculty });
                } else {
                    fields.push({ label: "Tên đăng nhập", value: data.code });
                    fields.push({ label: "Vai trò", value: data.role });
                }

                html += fields.map(f => `
                    <div class="detail-item">
                        <div class="detail-label">${f.label}</div>
                        <div class="detail-value">${f.value || "—"}</div>
                    </div>
                `).join("");

                content.innerHTML = html;
            } catch (e) {
                content.innerHTML = '<div class="text-danger p-4 text-center">Không thể tải thông tin.</div>';
            }
        }

        function closeModal() {
            document.getElementById('userModal').style.display = 'none';
        }

        function openAddModal(type) {
            const modalId = type === 'SV' ? 'addSvModal' : 'addGvModal';
            document.getElementById(modalId).style.display = 'flex';
        }

        function closeAddModal(type) {
            const modalId = type === 'SV' ? 'addSvModal' : 'addGvModal';
            document.getElementById(modalId).style.display = 'none';
        }

        async function submitAdd(e, type) {
            e.preventDefault();
            const form = e.target;
            const formData = new FormData(form);
            const data = Object.fromEntries(formData.entries());
            const url = type === 'SV' ? '@Url.Action("CreateStudent", "NguoiDung")' : '@Url.Action("CreateLecturer", "NguoiDung")';

            try {
                const res = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams(data)
                });
                const result = await res.json();
                if (result.success) {
                    alert(result.message);
                    location.reload();
                } else {
                    alert(result.message);
                }
            } catch (err) {
                alert("Lỗi kết nối hệ thống.");
            }
        }

        function toggleAddMenu(e) {
            e.stopPropagation();
            document.getElementById('addMenu').classList.toggle('show');
        }

        window.onclick = function(event) {
            const modal = document.getElementById('userModal');
            const svModal = document.getElementById('addSvModal');
            const gvModal = document.getElementById('addGvModal');
            const addMenu = document.getElementById('addMenu');

            if (event.target == modal) closeModal();
            if (event.target == svModal) closeAddModal('SV');
            if (event.target == gvModal) closeAddModal('GV');
            
            if (addMenu && !event.target.closest('.dropdown-custom')) {
                addMenu.classList.remove('show');
            }
        }
    </script>
}

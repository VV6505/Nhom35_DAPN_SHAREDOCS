<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UTE Admin Dashboard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HeThong_Admin.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="header">
        <a class="header-logo" href="@Url.Action("Index", "Home")">
            <img src="~/images/logo.webp" alt="UTE Logo" class="logo-img" />
            <div class="logo-text">
                HỆ THỐNG CHIA SẺ TÀI LIỆU<br />TRƯỜNG ĐẠI HỌC SƯ PHẠM KỸ THUẬT
            </div>
        </a>
        <div class="header-right">
            <div class="bell-wrap" id="bellWrap">
                <button class="bell-btn" onclick="toggleNotif()">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                        <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                    </svg>
                    <span class="bell-badge" id="bellCount">3</span>
                </button>

                <div class="notif-dropdown" id="notifDropdown">
                    <div class="notif-header">
                        <h4>Thông báo hệ thống</h4>
                        <a href="#" style="font-size: 11px;">Đã đọc tất cả</a>
                    </div>
                    <div class="notif-list">
                        <div class="notif-item unread">
                            <div class="notif-dot"></div>
                            <div class="notif-content">
                                <div class="notif-title">Có 5 tài liệu mới đang chờ duyệt</div>
                                <div class="notif-time">Mới đây</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="user-avatar">
                <div class="avatar">AQ</div>
                <span class="user-name">Admin Quang</span>
            </div>
        </div>
    </header>

    <div class="layout">
        <nav class="sidenav">
            <div class="nav-group-label">TỔNG QUAN</div>
            <a class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")"
               href="@Url.Action("Index", "Home")">
                <i class="nav-icon">📊</i> Xem thống kê
            </a>

            <div class="nav-group-label">QUẢN LÝ</div>
            <a class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "NguoiDung" ? "active" : "")"
               href="@Url.Action("Index", "NguoiDung")">
                <i class="nav-icon">👥</i> Quản lý người dùng
            </a>
            <a class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "DanhMuc" ? "active" : "")"
               href="@Url.Action("Index", "DanhMuc")">
                <i class="nav-icon">📁</i> Cập nhật danh mục
            </a>
            <a class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "DuyetTaiLieu" ? "active" : "")"
               href="@Url.Action("Index", "DuyetTaiLieu")">
                <i class="nav-icon">📄</i> Duyệt tài liệu
            </a>
            <a class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Bao Cao" ? "active" : "")"
               href="@Url.Action("Index", "Bao Cao")">
                <i class="nav-icon">⚠️</i> Báo cáo vi phạm
            </a>

            <div class="nav-group-label">HỆ THỐNG</div>
            <a class="nav-item" href="#">
                <i class="nav-icon">☁️</i> Sao lưu dữ liệu
            </a>
            <a class="nav-item" href="#">
                <i class="nav-icon">📈</i> Bảng xếp hạng
            </a>

            <div class="nav-divider"></div>
            <a class="nav-item logout" href="@Url.Action("Logout", "Account")"> 
                <i class="nav-icon">🚪</i> Đăng xuất
            </a>
        </nav>

        <main class="main-content">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        function toggleNotif() {
            document.getElementById("notifDropdown")?.classList.toggle("open");
        }

        document.addEventListener("click", function (e) {
            const bellWrap = document.getElementById("bellWrap");
            if (bellWrap && !bellWrap.contains(e.target)) {
                document.getElementById("notifDropdown")?.classList.remove("open");
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
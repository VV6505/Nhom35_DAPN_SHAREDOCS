@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Danh mục tài liệu";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

<div class="main-content py-4">
    <div class="container-fluid px-4">
        <div class="page-head mb-4">
            <h2 class="fw-bold">Danh mục tài liệu</h2>
            <p class="text-muted small">Duyệt tài liệu theo Khoa <i class="fa-solid fa-chevron-right mx-1"></i> Ngành <i class="fa-solid fa-chevron-right mx-1"></i> Môn học</p>
        </div>

        <div class="row">
            <div class="col-md-4 col-lg-3">
                <div class="card shadow-sm border-0" style="border-radius: 15px;">
                    <div class="card-header bg-white py-3 border-bottom-0">
                        <h6 class="fw-bold mb-0 text-primary"><i class="fa-solid fa-list-ul me-2"></i>Danh mục</h6>
                    </div>
                    <div class="card-body p-3 pt-0" style="max-height: 70vh; overflow-y: auto;">
                        <ul class="list-unstyled tree-menu">
                            @foreach (var khoa in ViewBag.DanhMuc)
                            {
                                <li class="mb-2">
                                    <div class="folder-toggle d-flex align-items-center py-1 fw-bold text-dark" style="cursor: pointer;">
                                        <i class="fa-solid fa-chevron-right me-2 small toggle-icon shadow-none"></i>
                                        <i class="fa-solid fa-folder text-warning me-2"></i> @khoa.TenKhoa
                                    </div>
                                    
                                    <ul class="list-unstyled ms-4 border-start ps-2 sub-menu" style="display: none;">
                                        @foreach (var nganh in khoa.Nganhs)
                                        {
                                            <li class="mb-1">
                                                <div class="nganh-toggle d-flex align-items-center py-1 text-secondary small fw-bold" style="cursor: pointer;">
                                                    <i class="fa-solid fa-chevron-right me-2 small toggle-icon"></i>
                                                    <i class="fa-solid fa-folder-open text-warning me-2 opacity-75"></i> @nganh.TenNganh
                                                </div>
                                                
                                                <ul class="list-unstyled ms-4 sub-menu" style="display: none;">
                                                    @foreach (var mon in nganh.MonHocs)
                                                    {
                                                        <li class="py-1">
                                                            <a href="/Document/Index?idMon=@mon.MaMonHoc&searchString=@ViewBag.SearchString" 
                                                               class="text-decoration-none small @(ViewBag.CurrentMon == mon.MaMonHoc ? "text-primary fw-bold" : "text-muted")">
                                                                <i class="fa-regular fa-file-lines me-2"></i> @mon.TenMonHoc (@mon.TaiLieus.Count)
                                                            </a>
                                                        </li>
                                                    }
                                                </ul>
                                            </li>
                                        }
                                    </ul>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-md-8 col-lg-9">
                <div class="card shadow-sm border-0" style="border-radius: 15px;">
                    <div class="card-body p-0">
                        <form asp-action="Index" method="get" class="p-3 border-bottom d-flex gap-2">
                            <input type="hidden" name="idMon" value="@ViewBag.CurrentMon" />
                            <div class="flex-grow-1 position-relative">
                                <i class="fa-solid fa-magnifying-glass position-absolute text-muted" style="left: 15px; top: 12px;"></i>
                                <input type="text" name="searchString" value="@ViewBag.SearchString" 
                                       class="form-control ps-5 rounded-pill border-0 bg-light" placeholder="Nhập tên tài liệu cần tìm...">
                            </div>
                            <button type="submit" class="btn btn-primary px-4 rounded-pill shadow-sm" style="background: #004d73;">Tìm kiếm</button>
                            @if (!string.IsNullOrEmpty(ViewBag.SearchString) || !string.IsNullOrEmpty(ViewBag.CurrentMon))
                            {
                                <a href="/Document/Index" class="btn btn-outline-secondary rounded-pill"><i class="fa-solid fa-rotate-left"></i> Xóa lọc</a>
                            }
                        </form>

                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr style="font-size: 11px;">
                                        <th class="ps-4 text-secondary text-uppercase py-3">Tên tài liệu</th>
                                        <th class="text-secondary text-uppercase">Người đăng</th>
                                        <th class="text-secondary text-uppercase text-center">Lượt tải</th>
                                        <th class="text-end pe-4">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <div class="fw-bold text-dark mb-0">@item.Data.TieuDe</div>
                                                <div class="text-muted small">Môn: @item.TenMon</div>
                                            </td>
                                            <td class="small text-muted">@item.TenNguoiDang</td>
                                            <td class="text-center fw-bold text-primary">@item.Data.LuotTai</td>
                                            <td class="text-end pe-4">
                                                <a href="/Document/Details/@item.Data.MaTaiLieu" class="btn btn-primary btn-sm px-4 rounded-pill shadow-sm" style="background: #004d73;">Xem</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .tree-menu li { transition: all 0.3s; }
    .toggle-icon { transition: transform 0.3s; font-size: 10px; }
    .rotate-90 { transform: rotate(90deg); }
    .tree-menu a:hover { color: #004d73 !important; text-decoration: underline !important; }
    .table-hover tbody tr:hover { background-color: #f8fbff; }
</style>
@section Scripts {
    <script>
        $(document).ready(function () {
            // --- PHẦN 1: XỬ LÝ CÂY THƯ MỤC (KHOA/NGÀNH/MÔN) ---
            $('.folder-toggle, .nganh-toggle').click(function (e) {
                var subMenu = $(this).next('.sub-menu');
                var icon = $(this).find('.toggle-icon');
                
                subMenu.slideToggle(300);
                icon.toggleClass('rotate-90');
            });

            // Tự động mở cây thư mục tại vị trí đang chọn
            $('.text-primary.fw-bold').parents('.sub-menu').show();
            $('.text-primary.fw-bold').parents('.sub-menu').prev().find('.toggle-icon').addClass('rotate-90');


            // --- PHẦN 2: TÔ MÀU XANH CHO SIDEBAR (VÁ LỖI LAYOUT) ---
            var currentUrl = window.location.pathname;

            $('.sidenav a').each(function () {
                var linkUrl = $(this).attr('href');

                // Xóa trạng thái active cũ
                $(this).closest('li').removeClass('active'); 
                $(this).css({
                    'background-color': 'transparent',
                    'border-left': 'none'
                });

                // Nếu link khớp với trang hiện tại thì tô màu xanh
                if (currentUrl === linkUrl) {
                    $(this).closest('li').addClass('active');
                    $(this).css({
                        'background-color': '#87CEFA', // Màu xanh nhạt
                        'border-left': '4px solid #004d73' // Thanh sọc đậm bên trái
                    });
                }
            });
        });
    </script>
}
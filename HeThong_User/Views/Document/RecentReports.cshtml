@model IEnumerable<HeThong_User.Models.BaoCaoViPham>

@{
    ViewData["Title"] = "Báo cáo vi phạm gần đây";
}

<div class="page-section active" style="display: block !important; padding: 20px;">
    <div class="d-flex align-items-center mb-4">
        <a href="/Home/Index" class="btn btn-outline-secondary btn-sm me-3"><i class="fa fa-arrow-left"></i> Trở về</a>
        <h4 class="fw-bold text-danger m-0">CÁC TÀI LIỆU BỊ BÁO CÁO GẦN ĐÂY</h4>
    </div>

    <div class="row">
        <div class="col-md-10 offset-md-1">
            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted">
                    <h5>Hiện tại chưa có báo cáo vi phạm nào.</h5>
                </div>
            }
            else
            {
                @foreach (var bc in Model)
                {
                    <div class="card shadow-sm border-0 mb-3 border-start border-4 border-danger">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h6 class="fw-bold mb-0">
                                    Tài liệu: <a href="/Document/Details/@bc.MaTaiLieu" class="text-primary text-decoration-none">@bc.MaTaiLieuNavigation?.TieuDe</a>
                                </h6>
                                <span class="badge @(bc.TrangThaiXuLy == "Chờ xử lý" ? "bg-warning text-dark" : "bg-success")">
                                    @bc.TrangThaiXuLy
                                </span>
                            </div>
                            
                            <div class="mb-2">
                                <span class="badge bg-danger-subtle text-danger border border-danger small">Lý do: @bc.LyDo</span>
                            </div>

                            <div class="bg-light p-2 rounded mb-2">
                                <p class="small text-muted mb-0"><strong>Nội dung phản ánh:</strong> @bc.MoTaChiTiet</p>
                            </div>

                            <div class="d-flex justify-content-between align-items-center text-muted" style="font-size: 11px;">
                                <span><i class="fa fa-user"></i> Người gửi: @bc.NguoiBaoCao</span>
                                <span><i class="fa fa-clock"></i> @bc.NgayBaoCao?.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>
@model IEnumerable<HeThong_User.Models.BaoCaoViPham>

@{
    ViewData["Title"] = "Báo cáo & Lịch sử";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

<div class="main-content py-4">
    <div class="container-fluid px-4">
        <div class="page-head mb-4">
            <h2 class="fw-bold mb-1">Báo cáo vi phạm</h2>
            <p class="text-muted small">Quản lý và gửi báo cáo về nội dung tài liệu</p>
        </div>

        <div class="row">
            <div class="col-lg-5 col-md-12 mb-4">
                <div class="card shadow-sm border-0" style="border-radius: 15px;">
                    <div class="card-header bg-white py-3 border-0">
                        <h6 class="fw-bold mb-0 text-danger"><i class="fa-solid fa-paper-plane me-2"></i>Gửi báo cáo mới</h6>
                    </div>
                    <div class="card-body pt-0">
                        <form asp-action="Report" method="post">
                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted">Tài liệu cần báo cáo</label>
                                <select name="MaTaiLieu" class="form-select bg-light border-0 py-2" required>
                                    <option value="">-- Chọn tài liệu --</option>
                                    @foreach (var tl in ViewBag.DanhSachTaiLieu)
                                    {
                                        @* Nếu ID trùng với ID truyền từ trang chi tiết thì thêm thuộc tính selected *@
                                        <option value="@tl.MaTaiLieu" selected="@(tl.MaTaiLieu == ViewBag.SelectedId ? "selected" : null)">
                                            @tl.TieuDe
                                        </option>
                                    }
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted">Lý do vi phạm</label>
                                <select name="LyDo" class="form-select bg-light border-0 py-2">
                                    <option>Vi phạm bản quyền</option>
                                    <option>Nội dung sai kiến thức</option>
                                    <option>File lỗi, không tải được</option>
                                    <option>Nội dung nhạy cảm</option>
                                </select>
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-bold text-muted">Mô tả chi tiết</label>
                                <textarea name="MoTaChiTiet" class="form-control bg-light border-0" rows="5" placeholder="Mô tả thêm để Admin dễ xử lý..."></textarea>
                            </div>

                            <button type="submit" class="btn btn-danger w-100 py-3 rounded-pill fw-bold shadow-sm" style="background-color: #d32f2f; border: none;">
                                Gửi báo cáo ngay
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-lg-7 col-md-12">
                <div class="card shadow-sm border-0" style="border-radius: 15px;">
                    <div class="card-header bg-white py-3 border-0">
                        <h6 class="fw-bold mb-0"><i class="fa-solid fa-clock-rotate-left me-2"></i>Lịch sử báo cáo của bạn</h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr style="font-size: 11px;">
                                        <th class="ps-4 text-secondary text-uppercase py-3">Tài liệu</th>
                                        <th class="text-secondary text-uppercase">Lý do</th>
                                        <th class="text-secondary text-uppercase">Ngày gửi</th>
                                        <th class="text-center">TT</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="ps-4 small fw-bold text-dark">
                                                @(item.MaTaiLieuNavigation?.TieuDe ?? item.MaTaiLieu)
                                            </td>
                                            <td class="small">@item.LyDo</td>
                                            <td class="small text-muted">@item.NgayBaoCao?.ToString("dd/MM/yyyy")</td>
                                            <td class="text-center">
                                                @if (item.TrangThaiXuLy == "Chờ xử lý")
                                                {
                                                    <span class="badge rounded-pill px-3 py-2" style="background-color: #fff8e1; color: #f57c00; font-size: 10px;">Đang chờ</span>
                                                }
                                                else
                                                {
                                                    <span class="badge rounded-pill px-3 py-2" style="background-color: #e8f5e9; color: #2e7d32; font-size: 10px;">Đã xong</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .form-select, .form-control { font-size: 13px; }
    .table-hover tbody tr:hover { background-color: #fff9f9; }
</style>
@section Scripts {
    <script>
        $(document).ready(function () {
            // 1. Xác định URL hiện tại của trang
            var currentUrl = window.location.pathname;

            // 2. Tìm tất cả các link trong Sidebar
            // Lưu ý: Thay '.sidenav a' bằng selector đúng trong code của Leader (ví dụ '.nav-link')
            $('.sidenav a').each(function () {
                var linkUrl = $(this).attr('href');

                // 3. Xóa màu xanh ở tất cả các mục trước khi tô màu mới
                // Thường Leader sẽ dùng class 'active' hoặc đổi màu background trực tiếp
                $(this).closest('li').removeClass('active'); 
                $(this).css('background-color', 'transparent'); // Reset màu nếu là style inline

                // 4. Nếu link trùng với URL hiện tại thì "tô xanh" nó
                if (currentUrl === linkUrl) {
                    // Nếu Leader dùng class để tô màu:
                    $(this).closest('li').addClass('active');
                    
                    // Nếu Leader tô màu bằng style trực tiếp (như trong ảnh):
                    $(this).css({
                        'background-color': '#87CEFA', // Màu xanh nhạt như trong ảnh
                        'border-left': '4px solid #004d73' // Thanh sọc đậm bên trái
                    });
                }
            });
        });
    </script>
}
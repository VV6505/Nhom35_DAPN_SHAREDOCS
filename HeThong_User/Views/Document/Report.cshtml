@model HeThong_User.Models.BaoCaoViPham

<div class="page-section active" style="display: block !important; padding: 20px;">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0 fw-bold"><i class="fa fa-exclamation-triangle"></i> BÁO CÁO VI PHẠM</h5>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted">Bạn đang báo cáo tài liệu: <strong>@ViewBag.TenTaiLieu</strong></p>
                    <form asp-action="Report" method="post">
                        <input type="hidden" asp-for="MaTaiLieu" value="@ViewBag.MaTaiLieu" />
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Lý do vi phạm</label>
                            <select asp-for="LyDo" class="form-select" required>
                                <option value="">-- Chọn lý do --</option>
                                <option value="Tài liệu sai kiến thức">Tài liệu sai kiến thức</option>
                                <option value="Vi phạm bản quyền">Vi phạm bản quyền</option>
                                <option value="File bị lỗi/Hỏng">File bị lỗi/Hỏng</option>
                                <option value="Nội dung không phù hợp">Nội dung không phù hợp</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Mô tả chi tiết</label>
                            <textarea asp-for="MoTaChiTiet" class="form-control" rows="4" placeholder="Cung cấp thêm thông tin để Admin xử lý nhanh hơn..."></textarea>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-danger">Gửi báo cáo</button>
                            <a href="/Document/Details/@ViewBag.MaTaiLieu" class="btn btn-link text-secondary">Hủy bỏ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
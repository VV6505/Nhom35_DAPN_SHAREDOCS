@model HeThong_User.Models.BaoCaoViPham

@{
    ViewData["Title"] = "Báo cáo vi phạm";
}

<div class="main-content py-5" style="background: #f4f4f4; min-height: 100vh;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card border-0 shadow-lg" style="border-radius: 12px; overflow: hidden;">
                    @* Header màu đỏ đặc trưng *@
                    <div class="card-header border-0 py-3" style="background-color: #d32f2f;">
                        <h5 class="text-white fw-bold mb-0 text-uppercase text-center">Báo cáo vi phạm</h5>
                    </div>
                    
                    <div class="card-body p-4 bg-white">
                        <p class="text-secondary small mb-4">Bạn đang báo cáo tài liệu: <strong class="text-dark">@ViewBag.TenTaiLieu</strong></p>

                        <form asp-action="Report" method="post">
                            <input type="hidden" asp-for="MaTaiLieu" value="@ViewBag.MaTaiLieu" />

                            <div class="mb-3">
                                <label class="form-label fw-bold small">Lý do vi phạm</label>
                                <select asp-for="LyDo" class="form-select py-2 border">
                                    <option value="">-- Chọn lý do --</option>
                                    <option>Tài liệu sai kiến thức</option>
                                    <option>Vi phạm bản quyền</option>
                                    <option>Nội dung nhạy cảm</option>
                                    <option>Lỗi file, không mở được</option>
                                </select>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold small">Mô tả chi tiết</label>
                                @* Sửa từ MoTa thành MoTaChiTiet *@
                                <textarea asp-for="MoTaChiTiet" class="form-control border" rows="5" placeholder="Cung cấp thêm thông tin để Admin xử lý nhanh hơn..."></textarea>
                            </div>

                            <button type="submit" class="btn btn-danger w-100 py-2 fw-bold mb-3" style="background-color: #d32f2f; border: none;">
                                Gửi báo cáo
                            </button>
                            
                            <div class="text-center">
                                <a href="javascript:history.back()" class="text-decoration-none small text-muted">Hủy bỏ</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@model HeThong_User.Models.TaiLieu

@{
    ViewData["Title"] = "Đăng tải tài liệu";
}

<div class="page-section active" style="display: block !important; padding: 20px;">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0 fw-bold"><i class="fa fa-upload"></i> ĐĂNG TẢI TÀI LIỆU MỚI</h5>
                </div>
                <div class="card-body p-4">
                    <!-- Quan trọng: Thuộc tính enctype="multipart/form-data" là BẮT BUỘC để upload file -->
                    <form asp-action="Upload" method="post" enctype="multipart/form-data">
                        
                        <!-- Hiển thị báo lỗi nếu có -->
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Tiêu đề tài liệu <span class="text-danger">*</span></label>
                            <input type="text" asp-for="TieuDe" class="form-control" placeholder="Nhập tên tài liệu..." required />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Môn học liên quan <span class="text-danger">*</span></label>
                                <select asp-for="MaMonHoc" class="form-select" required>
                                    <option value="">-- Chọn môn học --</option>
                                    @foreach (var mon in ViewBag.MaMonHoc)
                                    {
                                        <option value="@mon.MaMonHoc">@mon.TenMonHoc</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Loại tài liệu <span class="text-danger">*</span></label>
                                <select asp-for="MaloaiTl" class="form-select" required>
                                    <option value="">-- Chọn loại tài liệu --</option>
                                    @foreach (var loai in ViewBag.MaloaiTl)
                                    {
                                        <option value="@loai.MaLtl">@loai.TenLtl</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Mô tả ngắn (Tùy chọn)</label>
                            <textarea asp-for="MoTa" class="form-control" rows="3" placeholder="Ghi chú thêm về tài liệu..."></textarea>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Chọn File tải lên <span class="text-danger">*</span></label>
                            <input type="file" name="fileUpload" class="form-control" required accept=".pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.zip,.rar" />
                            <div class="form-text text-muted">Hỗ trợ định dạng: PDF, Word, PowerPoint, Excel, ZIP (Tối đa 50MB)</div>
                        </div>

                        <hr />
                        <div class="d-flex justify-content-end">
                            <a href="/Document/Index" class="btn btn-outline-secondary me-2">Hủy bỏ</a>
                            <button type="submit" class="btn btn-primary"><i class="fa fa-paper-plane"></i> Đăng tải ngay</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
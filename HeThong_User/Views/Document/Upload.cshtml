@model HeThong_User.Models.TaiLieu

@{
    ViewData["Title"] = "Đăng tải tài liệu";
}

@* Nhúng Font Awesome nếu file Layout chưa có *@
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

<div class="main-content py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="upload-header mb-4">
                    <h2 class="fw-bold mb-1">Đăng tải tài liệu</h2>
                    <p class="text-muted">Chia sẻ tài liệu với cộng đồng</p>
                </div>

                <div class="card shadow-sm border-0 p-4" style="border-radius: 15px;">
                    <form asp-action="Upload" method="post" enctype="multipart/form-data">
                        
                        <div class="form-group mb-3">
                            <label class="form-label fw-bold small text-secondary">Tên tài liệu</label>
                            <input asp-for="TieuDe" class="form-control bg-light border-0 py-2" placeholder="Nhập tên tài liệu..." required />
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-secondary">Môn học</label>
                                <select asp-for="MaMonHoc" class="form-select bg-light border-0 py-2">
                                    <option value="">Chọn môn</option>
                                    @foreach (var item in ViewBag.MaMonHoc)
                                    {
                                        <option value="@item.MaMonHoc">@item.TenMonHoc</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-secondary">Loại</label>
                                <select asp-for="MaloaiTl" class="form-select bg-light border-0 py-2">
                                    <option value="">Giáo trình</option>
                                    @foreach (var item in ViewBag.MaloaiTl)
                                    {
                                        <option value="@item.MaLtl">@item.TenLtl</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="form-group mb-4">
                            <label class="form-label fw-bold small text-secondary">Mô tả</label>
                            <textarea asp-for="MoTa" class="form-control bg-light border-0 py-2" rows="4" placeholder="Mô tả ngắn gọn..."></textarea>
                        </div>

                        <div class="form-group mb-4">
                            <label class="form-label fw-bold small text-secondary">Tải file</label>
                            <div class="upload-zone text-center p-5 border-dashed rounded-3 position-relative" id="drop-zone">
                                <input type="file" name="fileUpload" id="fileInput" class="position-absolute inset-0 opacity-0 w-100 h-100" style="cursor:pointer;" required />
                                <div class="upload-content">
                                    <i class="fa-solid fa-paperclip fa-2x mb-3 text-dark"></i>
                                    <p class="mb-1 text-secondary">Kéo thả hoặc <span class="text-primary fw-bold">chọn file</span></p>
                                    <p class="text-muted small mb-0">PDF, DOCX, PPTX - Tối đa 25MB</p>
                                    <div id="file-name" class="mt-2 fw-bold text-success small"></div>
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 fw-bold rounded-pill" style="background-color: #004d73; border: none;">
                            Đăng tải tài liệu
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* CSS Tùy chỉnh để giống ảnh mẫu */
    .border-dashed {
        border: 2px dashed #ccc;
        background-color: #fafafa;
        transition: 0.3s;
    }

        .border-dashed:hover {
            border-color: #004d73;
            background-color: #f0f7ff;
        }

    .form-control::placeholder, .form-select {
        font-size: 14px;
        color: #999;
    }

        .form-control:focus, .form-select:focus {
            background-color: #fff !important;
            box-shadow: 0 0 0 3px rgba(0,77,115,0.1);
        }

    .upload-zone i {
        transform: rotate(45deg);
    }
</style>

@section Scripts {
    <script>
        // Hiển thị tên file khi người dùng chọn
        document.getElementById('fileInput').addEventListener('change', function(e) {
            var fileName = e.target.files[0].name;
            document.getElementById('file-name').innerHTML = '<i class="fa-solid fa-check-circle"></i> Đã chọn: ' + fileName;
        });
    </script>
}
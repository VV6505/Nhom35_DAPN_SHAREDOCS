@model IEnumerable<HeThong_User.Models.TaiLieu>

@{
    ViewData["Title"] = "Trang chủ";
}

<div class="page-section active" style="display: block !important; padding: 20px;">
    <!-- 1. PHẦN THỐNG KÊ -->
    <div class="row mb-4">
        <!-- Click vào đây để sang danh sách tài liệu -->
        <div class="col-md-4">
            <a href="/Document/Index" class="text-decoration-none">
                <div class="card bg-primary text-white shadow-sm border-0 stat-card">
                    <div class="card-body d-flex align-items-center">
                        <div class="display-6 me-3"><i class="fa fa-file-alt"></i></div>
                        <div>
                            <h6 class="mb-0">TÀI LIỆU</h6>
                            <h2 class="mb-0 fw-bold">@ViewBag.TotalDocs</h2>
                        </div>
                    </div>
                </div>
            </a>
        </div>

        <!-- Click vào đây để xem danh sách sinh viên -->
        <div class="col-md-4">
            <a href="/Home/Students" class="text-decoration-none">
                <div class="card bg-success text-white shadow-sm border-0 stat-card">
                    <div class="card-body d-flex align-items-center">
                        <div class="display-6 me-3"><i class="fa fa-users"></i></div>
                        <div>
                            <h6 class="mb-0">SINH VIÊN</h6>
                            <h2 class="mb-0 fw-bold">@ViewBag.TotalUsers</h2>
                        </div>
                    </div>
                </div>
            </a>
        </div>

        <!-- Click vào đây để xem lịch sử tải xuống -->
        <div class="col-md-4">
            <a href="/Document/History" class="text-decoration-none">
                <div class="card bg-warning text-white shadow-sm border-0 stat-card">
                    <div class="card-body d-flex align-items-center">
                        <div class="display-6 me-3"><i class="fa fa-download"></i></div>
                        <div>
                            <h6 class="mb-0">LƯỢT TẢI</h6>
                            <h2 class="mb-0 fw-bold">@ViewBag.TotalDownloads</h2>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <!-- 2. PHẦN TÀI LIỆU MỚI NHẤT -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="fw-bold"><i class="fa fa-clock"></i> TÀI LIỆU MỚI ĐĂNG TẢI</h5>
        <a href="/Document/Index" class="btn btn-sm btn-link">Xem tất cả</a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
                    <div class="card-body">
                        <span class="badge bg-danger mb-2 small">@item.LoaiFile</span>
                        <h6 class="card-title fw-bold">@item.TieuDe</h6>
                        <p class="small text-muted mb-2">Môn: @item.MaMonHocNavigation?.TenMonHoc</p>
                        <div class="d-flex justify-content-between align-items-center pt-2 border-top">
                            <span class="text-warning small fw-bold">⭐ @item.DiemYeuCau điểm</span>
                            <a href="/Document/Details/@item.MaTaiLieu" class="btn btn-primary btn-sm rounded-pill px-3">Xem</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
    <style>
            .stat-card {
                transition: transform 0.2s, box-shadow 0.2s;
                cursor: pointer;
            }

                .stat-card:hover {
                    transform: scale(1.05);
                    box-shadow: 0 8px 15px rgba(0,0,0,0.2) !important;
                }
    </style>
</div>
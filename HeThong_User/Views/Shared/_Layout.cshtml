<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UTE Document Share</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&amp;display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="header">
      <a class="header-logo" asp-controller="Home" asp-action="Index">
            <img src="~/images/logo.webp" alt="UTE Logo" class="logo-img" />
            <div class="logo-text">
                HỆ THỐNG CHIA SẺ TÀI LIỆU<br />TRƯỜNG ĐẠI HỌC SƯ PHẠM KỸ THUẬT
            </div>
        </a>
        <div class="header-right">
            <div class="points-chip" title="Điểm tích lũy">
                <span class="points-ico">⭐</span>
                <span id="headerPoints">340</span>
            </div>
            <div class="bell-wrap" id="bellWrap">
                <button class="bell-btn" onclick="toggleNotif()">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                        <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                    </svg>
                    <span class="bell-badge" id="bellCount">4</span>
                </button>
                <div class="notif-dropdown" id="notifDropdown">
                    @* ... (Giữ nguyên nội dung notif-list từ code bạn gửi) ... *@
                </div>
            </div>
            <div class="user-avatar">
                <div class="avatar">PQ</div>
                <span class="user-name">Phạm Lê Thiệu Quang</span>
            </div>
        </div>
    </header>

    <div class="layout">
        <nav class="sidenav">
            <a class="nav-item active" onclick="showPage('dashboard', this)" href="/Home/Index">
                🏠 Trang chủ
            </a>
            <a class="nav-item" onclick="showPage('search', this)" href="/Document/Index">
                🔍 Danh mục tài liệu
            </a>
            <a class="nav-item" onclick="showPage('upload', this)" href="/Document/Upload">
                📤 Đăng tải tài liệu
            </a>
            <a class="nav-item" onclick="showPage('report', this)">
                🚩 Báo cáo vi phạm
            </a>
            <div class="nav-divider"></div>
            <a class="nav-item" onclick="showPage('profile', this)">
                👤 Thông tin cá nhân
            </a>
            <a class="nav-item" onclick="showPage('points', this)">
                ⭐ Điểm tích lũy
            </a>
            <a class="nav-item" onclick="showPage('personal', this)">
                📂 Tài liệu cá nhân
            </a>
            <div class="nav-divider"></div>
            <a class="nav-item logout" href="#">
                🚪 Đăng xuất
            </a>
        </nav>

        <main class="main-content">
            @RenderBody()
        </main>
    </div>

    <div class="modal-overlay" id="allNotifModal" onclick="if (event.target === this) closeAllNotif();">
        @* ... (Nội dung modal-box từ code bạn gửi) ... *@
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @* Copy toàn bộ thẻ script từ code của bạn vào đây *@
    <script>
        function showPage(p, el) {
            document.querySelectorAll(".page-section").forEach((s) => s.classList.remove("active"));
            document.querySelectorAll(".sidenav .nav-item").forEach((n) => n.classList.remove("active"));
            document.getElementById("page-" + p).classList.add("active");
            if (el) el.classList.add("active");
            closeNotif();
        }
        function toggleNotif() { document.getElementById("notifDropdown").classList.toggle("open"); }
        function closeNotif() { document.getElementById("notifDropdown").classList.remove("open"); }
        // ... Thêm các hàm còn lại của bạn ...
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
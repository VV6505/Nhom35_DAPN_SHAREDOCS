<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UTE Document Share</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&amp;display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="header">
      <a class="header-logo" asp-controller="Home" asp-action="Index">
            <img src="~/images/logo.webp" alt="UTE Logo" class="logo-img" />
            <div class="logo-text">
                HỆ THỐNG CHIA SẺ TÀI LIỆU<br />TRƯỜNG ĐẠI HỌC SƯ PHẠM KỸ THUẬT
            </div>
        </a>
        <div class="header-right">
            <div class="bell-wrap" id="bellWrap">
                <button class="bell-btn" onclick="toggleNotif()">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                        <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                    </svg>
                    <span class="bell-badge" id="bellCount">0</span>
                </button>
                <div class="notif-dropdown" id="notifDropdown">
                    <div class="notif-header">
                        <h4>Thông báo của bạn</h4>
                        <a href="#" style="font-size: 11px;">Đã đọc tất cả</a>
                    </div>
                    <div class="notif-list">
                        <div class="p-4 text-center text-muted">Đang tải thông báo...</div>
                    </div>
                </div>
            </div>
            <div class="user-avatar" id="userAvatarSection" title="Thông tin người dùng" onclick="toggleUserDropdown()">
                <div class="avatar" id="userAvatar">?</div>
                <span class="user-name" id="userName">Đang tải...</span>
                
                <!-- User Dropdown Menu -->
                <div class="user-dropdown" id="userDropdown">
                    <div class="user-dropdown-header">
                        <div class="user-dropdown-avatar" id="dropdownAvatar">?</div>
                        <div class="user-dropdown-name" id="dropdownName">Đang tải...</div>
                        <div class="user-dropdown-role" id="dropdownRole">
                            <span id="dropdownRoleIcon">👤</span>
                            <span id="dropdownRoleText">Người dùng</span>
                        </div>
                        <div class="user-dropdown-email" id="dropdownEmail"></div>
                    </div>
                    
                    <div class="user-dropdown-body">
                        <a href="@Url.Action("Index", "Profile")" class="user-dropdown-item">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                <circle cx="12" cy="7" r="4"/>
                            </svg>
                            <span class="user-dropdown-item-text">Thông tin cá nhân</span>
                        </a>
                        
                        <a href="@Url.Action("Index", "Points")" class="user-dropdown-item">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                            </svg>
                             <span class="user-dropdown-item-text">Điểm tích lũy</span>
                             <span class="user-dropdown-item-badge" id="dropdownPoints">0</span>
                         </a>
                        
                        <a href="@Url.Action("MyDocuments", "Documents")" class="user-dropdown-item">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                            </svg>
                            <span class="user-dropdown-item-text">Tài liệu của tôi</span>
                        </a>
                        
                        <div class="user-dropdown-divider"></div>
                        
                        <a href="@Url.Action("Settings", "Account")" class="user-dropdown-item">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="3"/>
                                <path d="M12 1v6m0 6v6m5.2-13.2l-4.2 4.2m0 6l4.2 4.2M23 12h-6m-6 0H1m18.2 5.2l-4.2-4.2m-6 0l-4.2 4.2"/>
                            </svg>
                            <span class="user-dropdown-item-text">Cài đặt</span>
                        </a>
                        
                        <a href="#" class="user-dropdown-item" onclick="showHelp(window.event)">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/>
                                <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
                                <line x1="12" y1="17" x2="12.01" y2="17"/>
                            </svg>
                            <span class="user-dropdown-item-text">Trợ giúp</span>
                        </a>
                    </div>
                    
                    <div class="user-dropdown-footer">
                        <button class="user-dropdown-logout" onclick="handleLogout(window.event)">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                                <polyline points="16 17 21 12 16 7"/>
                                <line x1="21" y1="12" x2="9" y2="12"/>
                            </svg>
                            <span>Đăng xuất</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div class="layout">
        <nav class="sidenav">
            <a class="nav-item active" href="@Url.Action("Index", "Home")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                    <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
                <span>Trang chủ</span>
            </a>
            <a class="nav-item" href="@Url.Action("Index", "Document")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"/>
                    <path d="m21 21-4.35-4.35"/>
                </svg>
                <span>Danh mục tài liệu</span>
            </a>
            <a class="nav-item" href="@Url.Action("Upload", "Document")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                    <polyline points="17 8 12 3 7 8"/>
                    <line x1="12" y1="3" x2="12" y2="15"/>
                </svg>
                <span>Đăng tải tài liệu</span>
            </a>
            <a class="nav-item" href="@Url.Action("RecentReports", "Document")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="12" y1="18" x2="12" y2="12"/>
                    <line x1="9" y1="15" x2="15" y2="15"/>
                </svg>
                <span>Báo cáo vi phạm</span>
            </a>
            <div class="nav-divider"></div>
            <a class="nav-item" href="@Url.Action("Index", "Profile")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
                <span>Thông tin cá nhân</span>
            </a>
            <a class="nav-item" href="@Url.Action("Index", "Points")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
                <span>Điểm tích lũy</span>
            </a>
            <a class="nav-item" href="@Url.Action("MyDocuments", "Documents")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                </svg>
                <span>Tài liệu cá nhân</span>
            </a>
            <div class="nav-divider"></div>
            <a class="nav-item logout" href="#">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                    <polyline points="16 17 21 12 16 7"/>
                    <line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
                <span>Đăng xuất</span>
            </a>
        </nav>

        <main class="main-content">
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mx-4 mt-3" role="alert" style="border-radius: 12px; border: none; box-shadow: 0 4px 12px rgba(220, 53, 69, 0.1);">
                    <i class="fa-solid fa-circle-exclamation me-2"></i> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mx-4 mt-3" role="alert" style="border-radius: 12px; border: none; box-shadow: 0 4px 12px rgba(25, 135, 84, 0.1);">
                    <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <div class="modal-overlay" id="allNotifModal" onclick="if ((event || window.event).target === this) closeAllNotif();">
        @* ... (Nội dung modal-box từ code bạn gửi) ... *@
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/auth.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // ============================================
        // CẬP NHẬT THÔNG TIN NGƯỜI DÙNG TỪ LOCALSTORAGE
        // ============================================
        
        function updateHeaderFromLocalStorage() {
            try {
                console.log('🔄 Đang cập nhật header từ localStorage...');
                
                if (!AuthManager.isLoggedIn()) {
                    console.log('⚠️ Chưa đăng nhập');
                    return;
                }
                
                const userInfo = AuthManager.getUserInfo();
                if (!userInfo) return;

                // Lấy dữ liệu (Chấp nhận cả PascalCase và camelCase)
                const tenNguoiDung = userInfo.tenNguoiDung || userInfo.TenNguoiDung || 
                                     userInfo.tenTaiKhoan || userInfo.TenTaiKhoan || 'Người dùng';
                const diemTichLuy = userInfo.diemTichLuy ?? userInfo.DiemTichLuy ?? 0;
                const loaiNguoiDung = (userInfo.loaiNguoiDung || userInfo.LoaiNguoiDung || '').toLowerCase();
                const tenVaiTro = userInfo.tenVaiTro || userInfo.TenVaiTro || (loaiNguoiDung === 'giangvien' ? 'Giảng viên' : 'Sinh viên');
                const initials = tenNguoiDung.split(' ').map(n => n[0]).join('').substring(0, 2).toUpperCase();
                
                // Icon vai trò
                const roleIcon = loaiNguoiDung === 'giangvien' ? '👨‍🏫' : '🎓';
                
                // 1. Cập nhật Tên và Avatar
                const userNameElement = document.getElementById('userName');
                const avatarElement = document.getElementById('userAvatar');
                
                if (userNameElement) userNameElement.textContent = tenNguoiDung;
                if (avatarElement) avatarElement.textContent = initials;
                
                // 2. Xử lý hiển thị vùng Điểm tích lũy
                const pointsChip = document.getElementById('pointsChip');
                const pointsSidebarItem = document.querySelector('a.nav-item[href*="/Points"]');
                const pointsDropdownItem = document.querySelector('a.user-dropdown-item[href*="/Points"]');

                // ẨN NẾU LÀ GIẢNG VIÊN
                if (loaiNguoiDung === 'giangvien' || loaiNguoiDung === 'admin') {
                    if (pointsChip) pointsChip.style.display = 'none';
                    if (pointsSidebarItem) pointsSidebarItem.style.display = 'none';
                    if (pointsDropdownItem) pointsDropdownItem.style.display = 'none';
                } else {
                    // HIỂN THỊ VỚI SINH VIÊN
                    if (pointsChip) pointsChip.style.display = 'flex';
                    const pointsElement = document.getElementById('headerPoints');
                    const dropdownPoints = document.getElementById('dropdownPoints');
                    if (pointsElement) pointsElement.textContent = diemTichLuy;
                    if (dropdownPoints) dropdownPoints.textContent = diemTichLuy;
                }
                
                // 3. Cập nhật các thông tin khác trong Dropdown
                const dropdownName = document.getElementById('dropdownName');
                const dropdownAvatar = document.getElementById('dropdownAvatar');
                const dropdownRoleText = document.getElementById('dropdownRoleText');
                if (dropdownName) dropdownName.textContent = tenNguoiDung;
                if (dropdownAvatar) dropdownAvatar.textContent = initials;
                if (dropdownRoleText) dropdownRoleText.textContent = tenVaiTro;

            } catch (err) {
                console.error('❌ Lỗi cập nhật Header:', err);
            }
        }
        
        // MỚI: Đồng bộ điểm từ Server về LocalStorage
        async function syncPointsWithServer() {
            try {
                const res = await fetch('/Home/GetLatestPoints');
                const result = await res.json();
                if (result.success) {
                    const userInfo = AuthManager.getUserInfo();
                    if (userInfo) {
                        userInfo.diemTichLuy = result.points;
                        userInfo.DiemTichLuy = result.points;
                        AuthManager.saveUserInfo(userInfo);
                        updateHeaderFromLocalStorage();
                    }
                }
            } catch (e) {
                console.error("Lỗi đồng bộ điểm:", e);
            }
        }

        window.addEventListener('focus', syncPointsWithServer);
        
        // ============================================
        // USER DROPDOWN MENU
        // ============================================
        
        function toggleUserDropdown() {
            const dropdown = document.getElementById('userDropdown');
            dropdown.classList.toggle('show');
            
            // Đóng dropdown khi click bên ngoài
            if (dropdown.classList.contains('show')) {
                setTimeout(() => {
                    document.addEventListener('click', closeDropdownOnClickOutside);
                }, 0);
            } else {
                document.removeEventListener('click', closeDropdownOnClickOutside);
            }
        }
        
        function closeDropdownOnClickOutside(event) {
            const dropdown = document.getElementById('userDropdown');
            const userAvatar = document.getElementById('userAvatarSection');
            
            if (!dropdown.contains(event.target) && !userAvatar.contains(event.target)) {
                dropdown.classList.remove('show');
                document.removeEventListener('click', closeDropdownOnClickOutside);
            }
        }
        
        function showPointsDetail(event) {
            event.preventDefault();
            const userInfo = AuthManager.getUserInfo();
            alert(`💰 Điểm tích lũy của bạn\n\nTổng điểm: ${userInfo.DiemTichLuy || 0} ⭐\n\nĐiểm được tích lũy từ:\n- Đăng tải tài liệu\n- Tài liệu được tải xuống\n- Đánh giá tích cực`);
        }
        
        // ============================================
        // USER DROPDOWN MENU
        // ============================================
        
        function toggleUserDropdown() {
            const dropdown = document.getElementById('userDropdown');
            if (!dropdown) return;
            
            const isShowing = dropdown.classList.contains('show');
            dropdown.classList.toggle('show');
            
            if (!isShowing) {
                // Đóng khi click ra ngoài
                setTimeout(() => {
                    document.addEventListener('click', closeDropdownOnClickOutside);
                }, 0);
            }
        }
        
        function closeDropdownOnClickOutside(event) {
            const dropdown = document.getElementById('userDropdown');
            const userAvatar = document.getElementById('userAvatarSection');
            
            if (dropdown && userAvatar && 
                !dropdown.contains(event.target) && 
                !userAvatar.contains(event.target)) {
                dropdown.classList.remove('show');
                document.removeEventListener('click', closeDropdownOnClickOutside);
            }
        }
        
        function showHelp(event) {
            event.preventDefault();
            alert('📚 Trợ giúp\n\nLiên hệ hỗ trợ:\n📧 Email: support@ute.edu.vn\n📞 Hotline: 1900-xxxx\n\nHoặc xem hướng dẫn sử dụng tại mục Trợ giúp.');
        }
        
        function handleLogout(event) {
            event.preventDefault();
            event.stopPropagation();
            
            const userInfo = AuthManager.getUserInfo();
            const userName = userInfo ? userInfo.TenNguoiDung : 'bạn';
            
            if (confirm(`${userName}, bạn có chắc chắn muốn đăng xuất?`)) {
                console.log('🚪 Đang đăng xuất...');
                
                // Đóng dropdown
                document.getElementById('userDropdown').classList.remove('show');
                
                // Xóa localStorage
                AuthManager.clearUserInfo();
                console.log('✅ Đã xóa localStorage');
                
                // Redirect về trang đăng xuất
                window.location.href = '@Url.Action("Logout", "Auth")';
            }
        }
        
        // ============================================
        // EVENT LISTENERS
        // ============================================
        
        // Chạy khi DOM load
        async function syncPointsWithServer() {
            try {
                const res = await fetch('/Home/GetLatestPoints');
                const result = await res.json();
                if (result.success) {
                    const userInfo = AuthManager.getUserInfo();
                    if (userInfo) {
                        userInfo.diemTichLuy = result.points;
                        userInfo.DiemTichLuy = result.points;
                        AuthManager.saveUserInfo(userInfo);
                        
                        const loaiNguoiDung = userInfo.loaiNguoiDung || userInfo.LoaiNguoiDung || '';
                        if (loaiNguoiDung !== 'GiangVien' && loaiNguoiDung !== 'giangvien') {
                            const pointsElement = document.getElementById('headerPoints');
                            const dropdownPoints = document.getElementById('dropdownPoints');
                            if (pointsElement) pointsElement.textContent = result.points;
                            if (dropdownPoints) dropdownPoints.textContent = result.points;
                        }
                    }
                }
            } catch (e) {
                console.error("Lỗi đồng bộ điểm:", e);
            }
        }

        window.addEventListener('focus', syncPointsWithServer);
        
        document.addEventListener('DOMContentLoaded', function() {
            console.log('📄 DOM loaded - Bắt đầu cập nhật header...');
            updateHeaderFromLocalStorage();
            syncPointsWithServer(); // Đồng bộ ngay khi load trang
            
            // Highlight active menu item based on current URL
            const currentPath = window.location.pathname;
            document.querySelectorAll('.sidenav .nav-item').forEach(item => {
                const href = item.getAttribute('href');
                if (href && href !== '#' && currentPath.includes(href)) {
                    item.classList.add('active');
                } else if (href === '#') {
                    // Keep onclick items
                } else {
                    item.classList.remove('active');
                }
            });
        });
        
        // Cập nhật lại khi window focus (user quay lại tab)
        window.addEventListener('focus', function() {
            console.log('👁️ Window focused - Kiểm tra session...');
            if (AuthManager.isLoggedIn() && AuthManager.isSessionExpired()) {
                alert('Phiên đăng nhập đã hết hạn!');
                AuthManager.clearUserInfo();
                window.location.href = '@Url.Action("Login", "Auth")';
            }
        });
        
        function toggleNotif() {
            const dropdown = document.getElementById("notifDropdown");
            if (!dropdown) return;
            
            dropdown.classList.toggle("open");
            
            if (dropdown.classList.contains("open")) {
                loadNotifications();
            }
        }

        async function loadNotifications() {
            const list = document.querySelector(".notif-list");
            if (!list) return;

            try {
                const res = await fetch('/Home/GetNotifications');
                const result = await res.json();
                
                if (result.success && result.data) {
                    const count = result.data.filter(n => n.trangThai === "Chưa đọc").length;
                    document.getElementById("bellCount").textContent = count;
                    document.getElementById("bellCount").style.display = count > 0 ? "flex" : "none";

                    if (result.data.length === 0) {
                        list.innerHTML = '<div class="p-4 text-center text-muted">Không có thông báo mới</div>';
                    } else {
                        list.innerHTML = result.data.map(n => `
                            <div class="notif-item ${n.trangThai === 'Chưa đọc' ? 'unread' : ''}">
                                ${n.trangThai === 'Chưa đọc' ? '<div class="notif-dot"></div>' : ''}
                                <div class="notif-content">
                                    <div class="notif-title" style="font-weight: 600; font-size: 14px;">${n.tieuDe}</div>
                                    <div class="notif-desc" style="font-size: 12px; color: #64748b; margin-top: 2px;">${n.noiDung}</div>
                                    <div class="notif-time" style="font-size: 11px; color: #94a3b8; margin-top: 4px;">${n.ngayTao}</div>
                                </div>
                            </div>
                        `).join('');
                    }
                }
            } catch (e) {
                console.error("Lỗi load thông báo:", e);
            }
        }

        // Tự động load số lượng khi trang tải
        document.addEventListener("DOMContentLoaded", async () => {
            try {
                const res = await fetch('/Home/GetNotifications');
                const result = await res.json();
                if (result.success && result.data) {
                    const count = result.data.filter(n => n.trangThai === "Chưa đọc").length;
                    const bellCount = document.getElementById("bellCount");
                    if (bellCount) {
                        bellCount.textContent = count;
                        bellCount.style.display = count > 0 ? "flex" : "none";
                    }
                }
            } catch(e) {}
        });

        function closeNotif() { 
            document.getElementById("notifDropdown").classList.remove("open"); 
        }

        document.addEventListener("click", function (e) {
            const bellWrap = document.getElementById("bellWrap");
            if (bellWrap && !bellWrap.contains(e.target)) {
                document.getElementById("notifDropdown")?.classList.remove("open");
            }
        });
        
        // Xử lý đăng xuất từ sidebar (legacy)
        document.querySelector('.logout')?.addEventListener('click', function(e) {
            e.preventDefault();
            handleLogout(e);
        });
        
        // Export function để có thể gọi từ nơi khác
        window.updateHeaderFromLocalStorage = updateHeaderFromLocalStorage;
        window.toggleUserDropdown = toggleUserDropdown;
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
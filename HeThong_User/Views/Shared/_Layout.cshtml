<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UTE Document Share</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="header">
        <a class="header-logo" href="@Url.Action("Index", "Home")">
            <img src="~/images/logo.webp" alt="UTE Logo" class="logo-img" />
            <div class="logo-text">
                HỆ THỐNG CHIA SẺ TÀI LIỆU<br />TRƯỜNG ĐẠI HỌC SƯ PHẠM KỸ THUẬT
            </div>
        </a>
        <div class="header-right">
            <div class="points-chip" title="Điểm tích lũy" id="pointsChip">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
                <span id="headerPoints">0</span>
            </div>
            <div class="bell-wrap" id="bellWrap">
                <button class="bell-btn" onclick="toggleNotif()">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                        <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                    </svg>
                    <span class="bell-badge" id="bellCount">4</span>
                </button>
                <div class="notif-dropdown" id="notifDropdown">
                    @* ... (Giữ nguyên nội dung notif-list từ code bạn gửi) ... *@
                </div>
            </div>
            <div class="user-avatar" id="userAvatarSection" title="Thông tin người dùng" onclick="toggleUserDropdown()">
                <div class="avatar" id="userAvatar">?</div>
                <span class="user-name" id="userName">Đang tải...</span>
                
                <!-- User Dropdown Menu -->
                <div class="user-dropdown" id="userDropdown">
                    <div class="user-dropdown-header">
                        <div class="user-dropdown-avatar" id="dropdownAvatar">?</div>
                        <div class="user-dropdown-name" id="dropdownName">Đang tải...</div>
                        <div class="user-dropdown-role" id="dropdownRole">
                            <span id="dropdownRoleIcon">👤</span>
                            <span id="dropdownRoleText">Người dùng</span>
                        </div>
                        <div class="user-dropdown-email" id="dropdownEmail"></div>
                    </div>
                    
                    <div class="user-dropdown-body">
                        <a href="@Url.Action("Index", "Profile")" class="user-dropdown-item">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                <circle cx="12" cy="7" r="4"/>
                            </svg>
                            <span class="user-dropdown-item-text">Thông tin cá nhân</span>
                        </a>
                        
                        <a href="@Url.Action("Index", "Points")" class="user-dropdown-item">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                            </svg>
                            <span class="user-dropdown-item-text">Điểm tích lũy</span>
                            <span class="user-dropdown-item-badge" id="dropdownPoints">0</span>
                        </a>
                        
                        <a href="@Url.Action("MyDocuments", "Documents")" class="user-dropdown-item">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                            </svg>
                            <span class="user-dropdown-item-text">Tài liệu của tôi</span>
                        </a>
                        
                        <div class="user-dropdown-divider"></div>
                        
                        <a href="@Url.Action("Settings", "Account")" class="user-dropdown-item">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="3"/>
                                <path d="M12 1v6m0 6v6m5.2-13.2l-4.2 4.2m0 6l4.2 4.2M23 12h-6m-6 0H1m18.2 5.2l-4.2-4.2m-6 0l-4.2 4.2"/>
                            </svg>
                            <span class="user-dropdown-item-text">Cài đặt</span>
                        </a>
                        
                        <a href="#" class="user-dropdown-item" onclick="showHelp(event)">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/>
                                <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
                                <line x1="12" y1="17" x2="12.01" y2="17"/>
                            </svg>
                            <span class="user-dropdown-item-text">Trợ giúp</span>
                        </a>
                    </div>
                    
                    <div class="user-dropdown-footer">
                        <button class="user-dropdown-logout" onclick="handleLogout(event)">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                                <polyline points="16 17 21 12 16 7"/>
                                <line x1="21" y1="12" x2="9" y2="12"/>
                            </svg>
                            <span>Đăng xuất</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div class="layout">
        <nav class="sidenav">
            <a class="nav-item active" href="@Url.Action("Index", "Home")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                    <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
                <span>Trang chủ</span>
            </a>
            <a class="nav-item" href="#">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"/>
                    <path d="m21 21-4.35-4.35"/>
                </svg>
                <span>Danh mục tài liệu</span>
            </a>
            <a class="nav-item" href="#">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                    <polyline points="17 8 12 3 7 8"/>
                    <line x1="12" y1="3" x2="12" y2="15"/>
                </svg>
                <span>Đăng tải tài liệu</span>
            </a>
            <a class="nav-item" href="#">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="12" y1="18" x2="12" y2="12"/>
                    <line x1="9" y1="15" x2="15" y2="15"/>
                </svg>
                <span>Báo cáo vi phạm</span>
            </a>
            <div class="nav-divider"></div>
            <a class="nav-item" href="@Url.Action("Index", "Profile")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
                <span>Thông tin cá nhân</span>
            </a>
            <a class="nav-item" href="@Url.Action("Index", "Points")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
                <span>Điểm tích lũy</span>
            </a>
            <a class="nav-item" href="@Url.Action("MyDocuments", "Documents")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                </svg>
                <span>Tài liệu cá nhân</span>
            </a>
            <div class="nav-divider"></div>
            <a class="nav-item logout" href="#">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                    <polyline points="16 17 21 12 16 7"/>
                    <line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
                <span>Đăng xuất</span>
            </a>
        </nav>

        <main class="main-content">
            @RenderBody()
        </main>
    </div>

    <div class="modal-overlay" id="allNotifModal" onclick="if (event.target === this) closeAllNotif();">
        @* ... (Nội dung modal-box từ code bạn gửi) ... *@
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/auth.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // ============================================
        // CẬP NHẬT THÔNG TIN NGƯỜI DÙNG TỪ LOCALSTORAGE
        // ============================================
        
        function updateHeaderFromLocalStorage() {
            console.log('🔄 Đang cập nhật header từ localStorage...');
            
            // Kiểm tra đăng nhập
            if (!AuthManager.isLoggedIn()) {
                console.log('⚠️ Chưa đăng nhập - Redirect về trang login');
                window.location.href = '@Url.Action("Login", "Auth")';
                return;
            }
            
            // Kiểm tra session timeout
            if (AuthManager.isSessionExpired()) {
                console.log('⚠️ Session đã hết hạn - Redirect về trang login');
                alert('Phiên đăng nhập đã hết hạn. Vui lòng đăng nhập lại!');
                AuthManager.clearUserInfo();
                window.location.href = '@Url.Action("Login", "Auth")';
                return;
            }
            
            const userInfo = AuthManager.getUserInfo();
            console.log('👤 User info:', userInfo);
            
            // FIX: Sử dụng key với chữ thường (camelCase) thay vì PascalCase
            const tenNguoiDung = userInfo.tenNguoiDung || userInfo.TenNguoiDung || 'User';
            const diemTichLuy = userInfo.diemTichLuy !== undefined ? userInfo.diemTichLuy : (userInfo.DiemTichLuy || 0);
            const email = userInfo.email || userInfo.Email || '';
            const loaiNguoiDung = userInfo.loaiNguoiDung || userInfo.LoaiNguoiDung || '';
            const tenVaiTro = userInfo.tenVaiTro || userInfo.TenVaiTro || loaiNguoiDung;
            
            console.log('📝 Parsed data:', { tenNguoiDung, diemTichLuy, email, loaiNguoiDung, tenVaiTro });
            
            // Lấy initials cho avatar
            const words = tenNguoiDung.trim().split(' ');
            let initials = '';
            if (words.length >= 2) {
                initials = words[0][0] + words[words.length - 1][0];
            } else if (words.length === 1) {
                initials = words[0].substring(0, 2);
            }
            initials = initials.toUpperCase();
            
            // Icon vai trò
            const roleIcon = loaiNguoiDung === 'SinhVien' || loaiNguoiDung === 'sinhvien' ? '🎓' : 
                            loaiNguoiDung === 'GiangVien' || loaiNguoiDung === 'giangvien' ? '👨‍🏫' : '👤';
            
            // 1. Cập nhật header avatar và tên
            const userNameElement = document.getElementById('userName');
            const avatarElement = document.getElementById('userAvatar');
            
            if (userNameElement) {
                userNameElement.textContent = tenNguoiDung;
                userNameElement.classList.remove('loading');
                console.log('✅ Đã cập nhật tên:', tenNguoiDung);
            }
            
            if (avatarElement) {
                avatarElement.textContent = initials;
                avatarElement.classList.add('loaded');
                console.log('✅ Đã cập nhật avatar:', initials);
            }
            
            // 2. Cập nhật điểm tích lũy
            const pointsElement = document.getElementById('headerPoints');
            if (pointsElement) {
                pointsElement.textContent = diemTichLuy;
                console.log('✅ Đã cập nhật điểm:', diemTichLuy);
                
                // Animation
                pointsElement.style.transition = 'transform 0.3s';
                pointsElement.style.transform = 'scale(1.2)';
                setTimeout(() => {
                    pointsElement.style.transform = 'scale(1)';
                }, 300);
            }
            
            // 3. Cập nhật dropdown
            const dropdownAvatar = document.getElementById('dropdownAvatar');
            const dropdownName = document.getElementById('dropdownName');
            const dropdownRole = document.getElementById('dropdownRole');
            const dropdownRoleIcon = document.getElementById('dropdownRoleIcon');
            const dropdownRoleText = document.getElementById('dropdownRoleText');
            const dropdownEmail = document.getElementById('dropdownEmail');
            const dropdownPoints = document.getElementById('dropdownPoints');
            
            if (dropdownAvatar) {
                dropdownAvatar.textContent = initials;
                console.log('✅ Đã cập nhật dropdown avatar');
            }
            if (dropdownName) {
                dropdownName.textContent = tenNguoiDung;
                console.log('✅ Đã cập nhật dropdown name');
            }
            if (dropdownRoleIcon) {
                dropdownRoleIcon.textContent = roleIcon;
            }
            if (dropdownRoleText) {
                dropdownRoleText.textContent = tenVaiTro;
                console.log('✅ Đã cập nhật dropdown role');
            }
            if (dropdownEmail) {
                dropdownEmail.textContent = email || 'Chưa có email';
                console.log('✅ Đã cập nhật dropdown email');
            }
            if (dropdownPoints) {
                dropdownPoints.textContent = diemTichLuy;
                console.log('✅ Đã cập nhật dropdown points');
            }
            
            // 4. Cập nhật tooltip
            const userAvatarSection = document.getElementById('userAvatarSection');
            if (userAvatarSection) {
                const tooltipText = `${tenNguoiDung}\n${roleIcon} ${tenVaiTro}\n⭐ ${diemTichLuy} điểm`;
                userAvatarSection.title = tooltipText;
            }
            
            const pointsChip = document.getElementById('pointsChip');
            if (pointsChip) {
                pointsChip.title = `${roleIcon} ${tenVaiTro} - Điểm tích lũy: ${diemTichLuy}`;
            }
            
            console.log('✅ Đã cập nhật header thành công!');
        }
        
        // ============================================
        // USER DROPDOWN MENU
        // ============================================
        
        function toggleUserDropdown() {
            const dropdown = document.getElementById('userDropdown');
            dropdown.classList.toggle('show');
            
            // Đóng dropdown khi click bên ngoài
            if (dropdown.classList.contains('show')) {
                setTimeout(() => {
                    document.addEventListener('click', closeDropdownOnClickOutside);
                }, 0);
            } else {
                document.removeEventListener('click', closeDropdownOnClickOutside);
            }
        }
        
        function closeDropdownOnClickOutside(event) {
            const dropdown = document.getElementById('userDropdown');
            const userAvatar = document.getElementById('userAvatarSection');
            
            if (!dropdown.contains(event.target) && !userAvatar.contains(event.target)) {
                dropdown.classList.remove('show');
                document.removeEventListener('click', closeDropdownOnClickOutside);
            }
        }
        
        function showPointsDetail(event) {
            event.preventDefault();
            const userInfo = AuthManager.getUserInfo();
            alert(`💰 Điểm tích lũy của bạn\n\nTổng điểm: ${userInfo.DiemTichLuy || 0} ⭐\n\nĐiểm được tích lũy từ:\n- Đăng tải tài liệu\n- Tài liệu được tải xuống\n- Đánh giá tích cực`);
        }
        
        function showHelp(event) {
            event.preventDefault();
            alert('📚 Trợ giúp\n\nLiên hệ hỗ trợ:\n📧 Email: support@ute.edu.vn\n📞 Hotline: 1900-xxxx\n\nHoặc xem hướng dẫn sử dụng tại mục Trợ giúp.');
        }
        
        function handleLogout(event) {
            event.preventDefault();
            event.stopPropagation();
            
            const userInfo = AuthManager.getUserInfo();
            const userName = userInfo ? userInfo.TenNguoiDung : 'bạn';
            
            if (confirm(`${userName}, bạn có chắc chắn muốn đăng xuất?`)) {
                console.log('🚪 Đang đăng xuất...');
                
                // Đóng dropdown
                document.getElementById('userDropdown').classList.remove('show');
                
                // Xóa localStorage
                AuthManager.clearUserInfo();
                console.log('✅ Đã xóa localStorage');
                
                // Redirect về trang đăng xuất
                window.location.href = '@Url.Action("Logout", "Auth")';
            }
        }
        
        // ============================================
        // EVENT LISTENERS
        // ============================================
        
        // Chạy khi DOM load
        document.addEventListener('DOMContentLoaded', function() {
            console.log('📄 DOM loaded - Bắt đầu cập nhật header...');
            updateHeaderFromLocalStorage();
            
            // Highlight active menu item based on current URL
            const currentPath = window.location.pathname;
            document.querySelectorAll('.sidenav .nav-item').forEach(item => {
                const href = item.getAttribute('href');
                if (href && href !== '#' && currentPath.includes(href)) {
                    item.classList.add('active');
                } else if (href === '#') {
                    // Keep onclick items
                } else {
                    item.classList.remove('active');
                }
            });
        });
        
        // Cập nhật lại khi window focus (user quay lại tab)
        window.addEventListener('focus', function() {
            console.log('👁️ Window focused - Kiểm tra session...');
            if (AuthManager.isLoggedIn() && AuthManager.isSessionExpired()) {
                alert('Phiên đăng nhập đã hết hạn!');
                AuthManager.clearUserInfo();
                window.location.href = '@Url.Action("Login", "Auth")';
            }
        });
        
        function toggleNotif() { 
            document.getElementById("notifDropdown").classList.toggle("open"); 
        }
        
        function closeNotif() { 
            document.getElementById("notifDropdown").classList.remove("open"); 
        }
        
        // Xử lý đăng xuất từ sidebar (legacy)
        document.querySelector('.logout')?.addEventListener('click', function(e) {
            e.preventDefault();
            handleLogout(e);
        });
        
        // Export function để có thể gọi từ nơi khác
        window.updateHeaderFromLocalStorage = updateHeaderFromLocalStorage;
        window.toggleUserDropdown = toggleUserDropdown;
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
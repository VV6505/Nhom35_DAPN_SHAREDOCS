<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hệ thống Tài liệu UTE</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HeThong_User.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="header">
        <a class="header-logo" href="@Url.Action("Index", "Home")">
            <img src="~/images/logo.webp" alt="UTE Logo" class="logo-img" />
            <div class="logo-text">
                HỆ THỐNG CHIA SẺ TÀI LIỆU<br />TRƯỜNG ĐẠI HỌC SƯ PHẠM KỸ THUẬT
            </div>
        </a>
        <div class="header-right">
            <div class="bell-wrap" id="bellWrap">
                <button class="bell-btn" onclick="toggleNotif()">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                        <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                    </svg>
                    <span class="bell-badge" id="bellCount">4</span>
                </button>

                <div class="notif-dropdown" id="notifDropdown">
                    <div class="notif-header">
                        <h4>Thông báo</h4>
                        <a href="#">Đã đọc tất cả</a>
                    </div>
                    <div class="notif-list">
                        <div class="notif-item unread">
                            <div class="notif-dot"></div>
                            <div class="notif-content">
                                <div class="notif-title">Tài liệu "Giáo trình CTDL&GT" đã được duyệt</div>
                                <div class="notif-time">5 phút trước</div>
                            </div>
                        </div>
                    </div>
                    <div class="notif-footer">
                        <a href="#">Xem tất cả thông báo →</a>
                    </div>
                </div>
            </div>
            <div class="user-avatar">
                <div class="avatar">PQ</div>
                <span class="user-name">Phạm Lê Thiệu Quang</span>
            </div>
        </div>
    </header>

    <div class="layout">
        <nav class="sidenav">
            <a class="nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")"
               href="@Url.Action("Index", "Home")">
                <i class="nav-icon">🏠</i> Trang chủ
            </a>
            <a class="nav-item" href="#">
                <i class="nav-icon">🔍</i> Danh mục tài liệu
            </a>
            <a class="nav-item" href="#">
                <i class="nav-icon">📤</i> Đăng tải tài liệu
            </a>
            <a class="nav-item" href="#">
                <i class="nav-icon">🚩</i> Báo cáo vi phạm
            </a>

            <div class="nav-divider"></div>

            <a class="nav-item" href="#">
                <i class="nav-icon">👤</i> Thông tin cá nhân
            </a>
            <a class="nav-item" href="#">
                <i class="nav-icon">⭐</i> Điểm tích lũy
            </a>
            <a class="nav-item" href="#">
                <i class="nav-icon">📂</i> Tài liệu cá nhân
            </a>

            <div class="nav-divider"></div>

            <a class="nav-item logout" href="#">
                <i class="nav-icon">🚪</i> Đăng xuất
            </a>
        </nav>

        <main class="main-content">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        function toggleNotif() {
            document.getElementById("notifDropdown")?.classList.toggle("open");
        }

        document.addEventListener("click", function (e) {
            const bellWrap = document.getElementById("bellWrap");
            if (bellWrap && !bellWrap.contains(e.target)) {
                document.getElementById("notifDropdown")?.classList.remove("open");
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>